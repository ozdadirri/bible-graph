ug":"pildash_2357","score":1},{"id":"rec7fgLqaIfnp70hX","type":"person","group":"mentioned","label":"Jidlaph","slug":"jidlaph_1615","score":1},{"id":"recDo9p41mKV8ptfj","type":"place","group":"mentioned","label":"Moriah","slug":"moriah_821","score":1},{"id":"rectrAkGtrZH5LMp8","type":"place","group":"mentioned","label":"Beersheba","slug":"beersheba_170","score":1}],"links":[{"source":"recLYU7Vp3rBfJOtm","target":"recIFusdNl6d8dj3L","label":"part of"},{"source":"recLYU7Vp3rBfJOtm","target":"reccdFYIq50NyxNej","label":"mentions"},{"source":"recLYU7Vp3rBfJOtm","target":"reccZB8SVU5bEMcgo","label":"mentions"},{"source":"recLYU7Vp3rBfJOtm","target":"recqIoG1fkaNWJ1y0","label":"mentions"},{"source":"recLYU7Vp3rBfJOtm","target":"recu1NkHTdTZhdbo7","label":"mentions"},{"source":"recLYU7Vp3rBfJOtm","target":"reco9eltuMG5wxarS","label":"mentions"},{"source":"recLYU7Vp3rBfJOtm","target":"reccN1xlFTOq0eIxu","label":"mentions"},{"source":"recLYU7Vp3rBfJOtm","target":"recj6ZXlovFO2zn8w","label":"mentions"},{"source":"recLYU7Vp3rBfJOtm","target":"recgmnMkaqehFaO02","label":"mentions"},{"source":"recLYU7Vp3rBfJOtm","target":"recKjlJpJDix9EmAN","label":"mentions"},{"source":"recLYU7Vp3rBfJOtm","target":"rec9yeIB6RsFeHdat","label":"mentions"},{"source":"recLYU7Vp3rBfJOtm","target":"recabOlnMn71maXKy","label":"mentions"},{"source":"recLYU7Vp3rBfJOtm","target":"recI0HcJ88bs71cyz","label":"mentions"},{"source":"recLYU7Vp3rBfJOtm","target":"recZ9IBATvc8daQSb","label":"mentions"},{"source":"recLYU7Vp3rBfJOtm","target":"rec7fgLqaIfnp70hX","label":"mentions"},{"source":"recLYU7Vp3rBfJOtm","target":"recDo9p41mKV8ptfj","label":"mentions"},{"source":"recLYU7Vp3rBfJOtm","target":"rectrAkGtrZH5LMp8","label":"mentions"}],"verses":[{"id":"recR5h7ifhPN0fzeI","ref":"Gen.22.1","text":"And it came to pass after these things, that God did tempt Abraham, and said unto him, Abraham: and he said, Behold, here I am.","year":-1872},{"id":"recIChWFVt96TgBPk","ref":"Gen.22.2","text":"And he said, Take now thy son, thine only son Isaac, whom thou lovest, and get thee into the land of Moriah; and offer him there for a burnt offering upon one of the mountains which I will tell thee of.","year":-1872},{"id":"rec7SbMmT3Bu03r7B","ref":"Gen.22.3","text":"And Abraham rose up early in the morning, and saddled his ass, and took two of his young men with him, and Isaac his son, and clave the wood for the burnt offering, and rose up, and went unto the place of which God had told him.","year":-1872},{"id":"recykoA1cyc8eqir3","ref":"Gen.22.4","text":"Then on the third day Abraham lifted up his eyes, and saw the place afar off.","year":-1872},{"id":"recJwNM5qkxHP8SnK","ref":"Gen.22.5","text":"And Abraham said unto his young men, Abide ye here with the ass; and I and the lad will go yonder and worship, and come again to you.","year":-1872},{"id":"reccRCJkEoVCMyCI0","ref":"Gen.22.6","text":"And Abraham took the wood of the burnt offering, and laid it upon Isaac his son; and he took the fire in his hand, and a knife; and they went both of them together.","year":-1872},{"id":"recKVfiKYcuQQ05T1","ref":"Gen.22.7","text":"And Isaac spake unto Abraham his father, and said, My father: and he said, Here am I, my son. And he said, Behold the fire and the wood: but where is the lamb for a burnt offering?","year":-1872},{"id":"recBbTteDB3wlhYY8","ref":"Gen.22.8","text":"And Abraham said, My son, God will provide himself a lamb for a burnt offering: so they went both of them together.","year":-1872}]}
