dPP0YOx","target":"recEtv9ql7Hh4XAW4","label":"mentions"},{"source":"rec20qS21pdPP0YOx","target":"rece9Qep7oMQHf1WS","label":"mentions"},{"source":"rec20qS21pdPP0YOx","target":"rec7dVcBSYkiLTKfA","label":"mentions"},{"source":"rec20qS21pdPP0YOx","target":"recE9JL6NWRxMRIWP","label":"mentions"},{"source":"rec20qS21pdPP0YOx","target":"recUoURurGRTnhD4Z","label":"mentions"},{"source":"rec20qS21pdPP0YOx","target":"recRZHTq3D9Hs5FG6","label":"mentions"},{"source":"rec20qS21pdPP0YOx","target":"recBZhqAvy5xhTNRn","label":"mentions"},{"source":"rec20qS21pdPP0YOx","target":"recFcRV7goLrcQm17","label":"mentions"},{"source":"rec20qS21pdPP0YOx","target":"recKsSsPEDA3H2QXE","label":"mentions"},{"source":"rec20qS21pdPP0YOx","target":"rec8SNX7XoTfkfbY1","label":"mentions"},{"source":"rec20qS21pdPP0YOx","target":"recdnhsOscx9k4Djn","label":"mentions"},{"source":"rec20qS21pdPP0YOx","target":"rec5dSSsOutWlH2fW","label":"mentions"},{"source":"rec20qS21pdPP0YOx","target":"recINYRGVbQuConLS","label":"mentions"},{"source":"rec20qS21pdPP0YOx","target":"reckq6qbK7CuwFOXD","label":"mentions"},{"source":"rec20qS21pdPP0YOx","target":"recW9pJRZ4cg9A2k6","label":"mentions"},{"source":"rec20qS21pdPP0YOx","target":"rec1k45DfZFLO3HfC","label":"mentions"},{"source":"rec20qS21pdPP0YOx","target":"recD6xiJWvESO0Wea","label":"event"},{"source":"rec20qS21pdPP0YOx","target":"recNLSBgKYUyByJwa","label":"event"}],"verses":[{"id":"recrgetVOfiUytsCt","ref":"Judg.8.1","text":"And the men of Ephraim said unto him, Why hast thou served us thus, that thou calledst us not, when thou wentest to fight with the Midianites? And they did chide with him sharply.","year":-1245},{"id":"reccpVZb8EpJS9ICd","ref":"Judg.8.2","text":"And he said unto them, What have I done now in comparison of you? Is not the gleaning of the grapes of Ephraim better than the vintage of Abiezer?","year":-1245},{"id":"recOvYgx5rvQO9F6i","ref":"Judg.8.3","text":"God hath delivered into your hands the princes of Midian, Oreb and Zeeb: and what was I able to do in comparison of you? Then their anger was abated toward him, when he had said that.","year":-1245},{"id":"recR1MMGkXDK7Rxh9","ref":"Judg.8.4","text":"And Gideon came to Jordan, and passed over, he, and the three hundred men that were with him, faint, yet pursuing them.","year":-1245},{"id":"recx1GpaeoMejdtmr","ref":"Judg.8.5","text":"And he said unto the men of Succoth, Give, I pray you, loaves of bread unto the people that follow me; for they be faint, and I am pursuing after Zebah and Zalmunna, kings of Midian.","year":-1245},{"id":"rec1vz8ddiBYb4VIh","ref":"Judg.8.6","text":"And the princes of Succoth said, Are the hands of Zebah and Zalmunna now in thine hand, that we should give bread unto thine army?","year":-1245},{"id":"recAUWm2EkBJWXRk7","ref":"Judg.8.7","text":"And Gideon said, Therefore when the LORD hath delivered Zebah and Zalmunna into mine hand, then I will tear your flesh with the thorns of the wilderness and with briers.","year":-1245},{"id":"recHtaRm1wJN9tR44","ref":"Judg.8.8","text":"And he went up thence to Penuel, and spake unto them likewise: and the men of Penuel answered him as the men of Succoth had answered him.","year":-1245}]}
