tm3CMyFRn64Tw","target":"reccZB8SVU5bEMcgo","label":"mentions"},{"source":"rec6tm3CMyFRn64Tw","target":"recBOUtTncbBlfEn9","label":"mentions"},{"source":"rec6tm3CMyFRn64Tw","target":"reck8CctXspLk0VZZ","label":"mentions"},{"source":"rec6tm3CMyFRn64Tw","target":"recmyzVBdbLEBB0Y0","label":"mentions"},{"source":"rec6tm3CMyFRn64Tw","target":"recOyMgubRhq1yatA","label":"mentions"},{"source":"rec6tm3CMyFRn64Tw","target":"recADz5cMmoTWAEzV","label":"mentions"},{"source":"rec6tm3CMyFRn64Tw","target":"rectFOmd9oBb0DoQ1","label":"mentions"},{"source":"rec6tm3CMyFRn64Tw","target":"recgAmwf1FZDe8DST","label":"mentions"},{"source":"rec6tm3CMyFRn64Tw","target":"recIJFRcqI6KbKgXb","label":"mentions"},{"source":"rec6tm3CMyFRn64Tw","target":"recekTocE5mIkvDEk","label":"event"}],"verses":[{"id":"recSo90ih7OFp7iUd","ref":"Hos.5.1","text":"Hear ye this, O priests; and hearken, ye house of Israel; and give ye ear, O house of the king; for judgment is toward you, because ye have been a snare on Mizpah, and a net spread upon Tabor.","year":-780},{"id":"rec8BQRu1gyfx3Qbi","ref":"Hos.5.2","text":"And the revolters are profound to make slaughter, though I have been a rebuker of them all.","year":-780},{"id":"recpiiBKEGreOm21T","ref":"Hos.5.3","text":"I know Ephraim, and Israel is not hid from me: for now, O Ephraim, thou committest whoredom, and Israel is defiled.","year":-780},{"id":"rec4KmZFu6fLAW9pY","ref":"Hos.5.4","text":"They will not frame their doings to turn unto their God: for the spirit of whoredoms is in the midst of them, and they have not known the LORD.","year":-780},{"id":"recMYWJToIhRE0Lzr","ref":"Hos.5.5","text":"And the pride of Israel doth testify to his face: therefore shall Israel and Ephraim fall in their iniquity; Judah also shall fall with them.","year":-780},{"id":"recKz6QRvQFNEvhEs","ref":"Hos.5.6","text":"They shall go with their flocks and with their herds to seek the LORD; but they shall not find him; he hath withdrawn himself from them.","year":-780},{"id":"recgbl4f0VS6nWuAl","ref":"Hos.5.7","text":"They have dealt treacherously against the LORD: for they have begotten strange children: now shall a month devour them with their portions.","year":-780},{"id":"rec9F0fBqomtwlGGM","ref":"Hos.5.8","text":"Blow ye the cornet in Gibeah, and the trumpet in Ramah: cry aloud at Bethaven, after thee, O Benjamin.","year":-780}]}
