pu0gY6REK","label":"mentions"},{"source":"recZT1POfc2v5Zfwo","target":"recqGPFiXFCSGzkRz","label":"mentions"},{"source":"recZT1POfc2v5Zfwo","target":"recIyAl1ABkxftXEJ","label":"mentions"},{"source":"recZT1POfc2v5Zfwo","target":"recWYX1muoIyGHXv0","label":"mentions"},{"source":"recZT1POfc2v5Zfwo","target":"recfllsQUd2NKmHuq","label":"mentions"},{"source":"recZT1POfc2v5Zfwo","target":"recIEStdFe3IQjHq0","label":"mentions"},{"source":"recZT1POfc2v5Zfwo","target":"recEpJ5lnOu8GMLvr","label":"mentions"},{"source":"recZT1POfc2v5Zfwo","target":"recL1WV82pXaRBQ59","label":"mentions"},{"source":"recZT1POfc2v5Zfwo","target":"recpqKANUDcRgN4HU","label":"mentions"},{"source":"recZT1POfc2v5Zfwo","target":"recYsXWjhw6FUqHLY","label":"mentions"},{"source":"recZT1POfc2v5Zfwo","target":"rec81kc1ekka6u5Ac","label":"mentions"},{"source":"recZT1POfc2v5Zfwo","target":"rec81f3wE4gATsRRE","label":"mentions"},{"source":"recZT1POfc2v5Zfwo","target":"recOpGyXVzzKCuVs5","label":"mentions"},{"source":"recZT1POfc2v5Zfwo","target":"recwPACgpqabJeUvd","label":"mentions"},{"source":"recZT1POfc2v5Zfwo","target":"recVYcDguYN6bVqxy","label":"mentions"},{"source":"recZT1POfc2v5Zfwo","target":"recUKTEJITTiKkrpe","label":"mentions"},{"source":"recZT1POfc2v5Zfwo","target":"rec4IK8BRFWJUhjhQ","label":"mentions"}],"verses":[{"id":"recwxTuDyMxrLQp7N","ref":"Neh.7.1","text":"Now it came to pass, when the wall was built, and I had set up the doors, and the porters and the singers and the Levites were appointed,","year":-445},{"id":"recfAYpSTsv3onQFy","ref":"Neh.7.2","text":"That I gave my brother Hanani, and Hananiah the ruler of the palace, charge over Jerusalem: for he was a faithful man, and feared God above many.","year":-445},{"id":"recLiGtVVDt5MvoBg","ref":"Neh.7.3","text":"And I said unto them, Let not the gates of Jerusalem be opened until the sun be hot; and while they stand by, let them shut the doors, and bar them: and appoint watches of the inhabitants of Jerusalem, every one in his watch, and every one to be over against his house.","year":-445},{"id":"recF2EgJUnPUTahHg","ref":"Neh.7.4","text":"Now the city was large and great: but the people were few therein, and the houses were not builded.","year":-445},{"id":"recPPU6JkM2fjDz8W","ref":"Neh.7.5","text":"And my God put into mine heart to gather together the nobles, and the rulers, and the people, that they might be reckoned by genealogy. And I found a register of the genealogy of them which came up at the first, and found written therein,","year":-445},{"id":"recyQQTXIh7QVnjN4","ref":"Neh.7.6","text":"These are the children of the province, that went up out of the captivity, of those that had been carried away, whom Nebuchadnezzar the king of Babylon had carried away, and came again to Jerusalem and to Judah, every one unto his city;","year":-445},{"id":"recooZrcVI1nXiqhe","ref":"Neh.7.7","text":"Who came with Zerubbabel, Jeshua, Nehemiah, Azariah, Raamiah, Nahamani, Mordecai, Bilshan, Mispereth, Bigvai, Nehum, Baanah. The number, I say, of the men of the people of Israel was this;","year":-445},{"id":"recakAPnBAAlX5LP9","ref":"Neh.7.8","text":"The children of Parosh, two thousand an hundred seventy and two.","year":-445}]}
