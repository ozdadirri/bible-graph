d","label":"Meshullam","slug":"meshullam_2031","score":1},{"id":"recVOlizYMBS7vgVN","type":"person","group":"mentioned","label":"Berechiah","slug":"berechiah_474","score":1},{"id":"recCnbP6ZTjAmPCnR","type":"place","group":"mentioned","label":"Ono","slug":"ono_909","score":1},{"id":"rec2PCmwHsVx97kxs","type":"place","group":"mentioned","label":"Hakkephirim","slug":"hakkephirim_507","score":1},{"id":"recL1WV82pXaRBQ59","type":"place","group":"mentioned","label":"Jerusalem","slug":"jerusalem_636","score":1}],"links":[{"source":"recfEkptwxDwE0W5t","target":"rec3WEGPl0a1PS0cC","label":"part of"},{"source":"recfEkptwxDwE0W5t","target":"rec52hiVeIo48q2Ru","label":"mentions"},{"source":"recfEkptwxDwE0W5t","target":"rec9vPGKxQFFBO3Jd","label":"mentions"},{"source":"recfEkptwxDwE0W5t","target":"reccZB8SVU5bEMcgo","label":"mentions"},{"source":"recfEkptwxDwE0W5t","target":"recxHwCuYM5GgWUFC","label":"mentions"},{"source":"recfEkptwxDwE0W5t","target":"recKeZqfwhvjXKUUS","label":"mentions"},{"source":"recfEkptwxDwE0W5t","target":"recZSVfKVbDghwXa2","label":"mentions"},{"source":"recfEkptwxDwE0W5t","target":"recAAOzX8L7AzGzGC","label":"mentions"},{"source":"recfEkptwxDwE0W5t","target":"recThllvpmhvgkTrs","label":"mentions"},{"source":"recfEkptwxDwE0W5t","target":"recN8mDN9ihZoI22V","label":"mentions"},{"source":"recfEkptwxDwE0W5t","target":"recnkVU8OpMCiLHf6","label":"mentions"},{"source":"recfEkptwxDwE0W5t","target":"recOf0COw4bHshLcQ","label":"mentions"},{"source":"recfEkptwxDwE0W5t","target":"recBJnNOjtW11kqDn","label":"mentions"},{"source":"recfEkptwxDwE0W5t","target":"rec39Q71KaVv2Z8Gf","label":"mentions"},{"source":"recfEkptwxDwE0W5t","target":"recVOlizYMBS7vgVN","label":"mentions"},{"source":"recfEkptwxDwE0W5t","target":"recCnbP6ZTjAmPCnR","label":"mentions"},{"source":"recfEkptwxDwE0W5t","target":"rec2PCmwHsVx97kxs","label":"mentions"},{"source":"recfEkptwxDwE0W5t","target":"recL1WV82pXaRBQ59","label":"mentions"}],"verses":[{"id":"recMzgNAU77frOvHH","ref":"Neh.6.1","text":"Now it came to pass, when Sanballat, and Tobiah, and Geshem the Arabian, and the rest of our enemies, heard that I had builded the wall, and that there was no breach left therein; (though at that time I had not set up the doors upon the gates;)","year":-445},{"id":"reccoBalnj2mSzT2A","ref":"Neh.6.2","text":"That Sanballat and Geshem sent unto me, saying, Come, let us meet together in some one of the villages in the plain of Ono. But they thought to do me mischief.","year":-445},{"id":"recO6durt1XEkTiKT","ref":"Neh.6.3","text":"And I sent messengers unto them, saying, I am doing a great work, so that I cannot come down: why should the work cease, whilst I leave it, and come down to you?","year":-445},{"id":"recHf7iq20ccTeAPJ","ref":"Neh.6.4","text":"Yet they sent unto me four times after this sort; and I answered them after the same manner.","year":-445},{"id":"recsTtVjkihufAHaH","ref":"Neh.6.5","text":"Then sent Sanballat his servant unto me in like manner the fifth time with an open letter in his hand;","year":-445},{"id":"recYHi62FHMqdeVq1","ref":"Neh.6.6","text":"Wherein was written, It is reported among the heathen, and Gashmu saith it, that thou and the Jews think to rebel: for which cause thou buildest the wall, that thou mayest be their king, according to these words.","year":-445},{"id":"recjJeegvCr3nIy5O","ref":"Neh.6.7","text":"And thou hast also appointed prophets to preach of thee at Jerusalem, saying, There is a king in Judah: and now shall it be reported to the king according to these words. Come now therefore, and let us take counsel together.","year":-445},{"id":"rec6Rt5dgnGMGZ23D","ref":"Neh.6.8","text":"Then I sent unto him, saying, There are no such things done as thou sayest, but thou feignest them out of thine own heart.","year":-445}]}
