heir names: of the tribe of Reuben, Shammua the son of Zaccur.","year":-1490},{"id":"recUu7ZBv4BLmwsqe","ref":"Num.13.5","text":"Of the tribe of Simeon, Shaphat the son of Hori.","year":-1490},{"id":"recWyWTjIkszdZ0Xm","ref":"Num.13.6","text":"Of the tribe of Judah, Caleb the son of Jephunneh.","year":-1490},{"id":"recvAttnUufxU2U2H","ref":"Num.13.7","text":"Of the tribe of Issachar, Igal the son of Joseph.","year":-1490},{"id":"recxDIRM3c3N1XW5U","ref":"Num.13.8","text":"Of the tribe of Ephraim, Oshea the son of Nun.","year":-1490}]}
