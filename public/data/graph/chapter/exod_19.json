ryCmk","target":"rec5Yu6987dc60uKz","label":"mentions"},{"source":"recRMThnEcQhryCmk","target":"rec6V51IWkgvAcnOU","label":"mentions"},{"source":"recRMThnEcQhryCmk","target":"recfrXyxhuYOczKTm","label":"mentions"},{"source":"recRMThnEcQhryCmk","target":"recop6QEHQoHhwytR","label":"mentions"},{"source":"recRMThnEcQhryCmk","target":"reca8LvAmFPl1tmnN","label":"event"}],"verses":[{"id":"rectxzIFGot5uwef0","ref":"Exod.19.1","text":"In the third month, when the children of Israel were gone forth out of the land of Egypt, the same day came they into the wilderness of Sinai.","year":-1491},{"id":"recNPm2fp1hdBacG4","ref":"Exod.19.2","text":"For they were departed from Rephidim, and were come to the desert of Sinai, and had pitched in the wilderness; and there Israel camped before the mount.","year":-1491},{"id":"recGm0V87gzYOHvQ1","ref":"Exod.19.3","text":"And Moses went up unto God, and the LORD called unto him out of the mountain, saying, Thus shalt thou say to the house of Jacob, and tell the children of Israel;","year":-1491},{"id":"recIQG2SWjVya78uF","ref":"Exod.19.4","text":"Ye have seen what I did unto the Egyptians, and how I bare you on eagles’ wings, and brought you unto myself.","year":-1491},{"id":"recd7227Z52v6URbk","ref":"Exod.19.5","text":"Now therefore, if ye will obey my voice indeed, and keep my covenant, then ye shall be a peculiar treasure unto me above all people: for all the earth is mine:","year":-1491},{"id":"recbJkaFOsPQxmnBU","ref":"Exod.19.6","text":"And ye shall be unto me a kingdom of priests, and an holy nation. These are the words which thou shalt speak unto the children of Israel.","year":-1491},{"id":"recjU2q98xBsZcmcb","ref":"Exod.19.7","text":"And Moses came and called for the elders of the people, and laid before their faces all these words which the LORD commanded him.","year":-1491},{"id":"recpjj5I1knwxsiLz","ref":"Exod.19.8","text":"And all the people answered together, and said, All that the LORD hath spoken we will do. And Moses returned the words of the people unto the LORD.","year":-1491}]}
