cz1arTM9CQhDhy0","target":"reccZB8SVU5bEMcgo","label":"mentions"},{"source":"recz1arTM9CQhDhy0","target":"rec9lplwEhGgkXdOn","label":"mentions"},{"source":"recz1arTM9CQhDhy0","target":"recjMT68aIzFLh6cQ","label":"mentions"},{"source":"recz1arTM9CQhDhy0","target":"recZsS2Zu0zIDwqdv","label":"mentions"},{"source":"recz1arTM9CQhDhy0","target":"rec1ZMFtfbEvoGC73","label":"mentions"},{"source":"recz1arTM9CQhDhy0","target":"reco82mzy0XTzaOgv","label":"mentions"},{"source":"recz1arTM9CQhDhy0","target":"recMrPw4PinNqXItV","label":"mentions"},{"source":"recz1arTM9CQhDhy0","target":"recrMw6oWCF0eXTjI","label":"mentions"},{"source":"recz1arTM9CQhDhy0","target":"rec3MO3I7NnWikHuv","label":"mentions"},{"source":"recz1arTM9CQhDhy0","target":"rec81f3wE4gATsRRE","label":"mentions"},{"source":"recz1arTM9CQhDhy0","target":"reczeMGDnN4eb0Y28","label":"mentions"},{"source":"recz1arTM9CQhDhy0","target":"recKRsEFLaEueJvei","label":"event"}],"verses":[{"id":"recRw3Rxp4FWPvypD","ref":"1Sam.16.1","text":"And the LORD said unto Samuel, How long wilt thou mourn for Saul, seeing I have rejected him from reigning over Israel? fill thine horn with oil, and go, I will send thee to Jesse the Bethlehemite: for I have provided me a king among his sons.","year":-1063},{"id":"rec5pz6kuUTiBbt9O","ref":"1Sam.16.2","text":"And Samuel said, How can I go? if Saul hear it, he will kill me. And the LORD said, Take an heifer with thee, and say, I am come to sacrifice to the LORD.","year":-1063},{"id":"recmhzXd41UlWdPBv","ref":"1Sam.16.3","text":"And call Jesse to the sacrifice, and I will shew thee what thou shalt do: and thou shalt anoint unto me him whom I name unto thee.","year":-1063},{"id":"recUJDF75oxR3G1JY","ref":"1Sam.16.4","text":"And Samuel did that which the LORD spake, and came to Bethlehem. And the elders of the town trembled at his coming, and said, Comest thou peaceably?","year":-1063},{"id":"recsPEeCEpWoM5edn","ref":"1Sam.16.5","text":"And he said, Peaceably: I am come to sacrifice unto the LORD: sanctify yourselves, and come with me to the sacrifice. And he sanctified Jesse and his sons, and called them to the sacrifice.","year":-1063},{"id":"recB2G2QmcUxk9xQ2","ref":"1Sam.16.6","text":"And it came to pass, when they were come, that he looked on Eliab, and said, Surely the LORD’S anointed is before him.","year":-1063},{"id":"recU6EKv6u8ZCyClH","ref":"1Sam.16.7","text":"But the LORD said unto Samuel, Look not on his countenance, or on the height of his stature; because I have refused him: for the LORD seeth not as man seeth; for man looketh on the outward appearance, but the LORD looketh on the heart.","year":-1063},{"id":"recYkmiII4M49lpQ4","ref":"1Sam.16.8","text":"Then Jesse called Abinadab, and made him pass before Samuel. And he said, Neither hath the LORD chosen this.","year":-1063}]}
