{"entity":{"id":"rec6ugLKho1VOqbm6","type":"chapter","slug":"rec6ugLKho1VOqbm6","label":"Job.23","rawId":"rec6ugLKho1VOqbm6","book":{"id":"recOA8nVVhKs30PSI","type":"book","slug":"job","label":"Job","subtitle":"Poetry-Wisdom","count":1070,"description":"42 chapters, 190 people, 6 places"}},"stats":{"verses":17,"people":2,"places":0,"events":1},"nodes":[{"id":"rec6ugLKho1VOqbm6","type":"chapter","group":"focus","label":"Job.23","slug":"job_23","score":17},{"id":"recOA8nVVhKs30PSI","type":"book","group":"book","label":"Job","slug":"job","score":1070},{"id":"recKXL1QrW8qTw5Ux","type":"person","group":"mentioned","label":"Job","slug":"job_1639","score":1},{"id":"reccZB8SVU5bEMcgo","type":"person","group":"mentioned","label":"God","slug":"god_1324","score":1},{"id":"recMNT9RB1RJiLlYW","type":"event","group":"event","label":"Job's Trial","slug":"event-117","score":17}],"links":[{"source":"rec6ugLKho1VOqbm6","target":"recOA8nVVhKs30PSI","label":"part of"},{"source":"rec6ugLKho1VOqbm6","target":"recKXL1QrW8qTw5Ux","label":"mentions"},{"source":"rec6ugLKho1VOqbm6","target":"reccZB8SVU5bEMcgo","label":"mentions"},{"source":"rec6ugLKho1VOqbm6","target":"recMNT9RB1RJiLlYW","label":"event"}],"verses":[{"id":"rec5qO6Lnvpfrvtdt","ref":"Job.23.1","text":"Then Job answered and said,","year":-1520},{"id":"rec1S4l3xlCbn9lnZ","ref":"Job.23.2","text":"Even to day is my complaint bitter: my stroke is heavier than my groaning.","year":-1520},{"id":"rec0Rxms7MYZkJeVz","ref":"Job.23.3","text":"Oh that I knew where I might find him! that I might come even to his seat!","year":-1520},{"id":"recWrPjh4uu7C8uVo","ref":"Job.23.4","text":"I would order my cause before him, and fill my mouth with arguments.","year":-1520},{"id":"recFeRh3qA0nevy7a","ref":"Job.23.5","text":"I would know the words which he would answer me, and understand what he would say unto me.","year":-1520},{"id":"recgiBg2k4RswzgNq","ref":"Job.23.6","text":"Will he plead against me with his great power? No; but he would put strength in me.","year":-1520},{"id":"rec939oYQhmnivmCO","ref":"Job.23.7","text":"There the righteous might dispute with him; so should I be delivered for ever from my judge.","year":-1520},{"id":"recP9IsDW2Bd0sgUQ","ref":"Job.23.8","text":"Behold, I go forward, but he is not there; and backward, but I cannot perceive him:","year":-1520}]}
