{"entity":{"id":"rec2cddorsDxouJ4k","type":"chapter","slug":"rec2cddorsDxouJ4k","label":"Rom.4","rawId":"rec2cddorsDxouJ4k","book":{"id":"recyvIyxRMFob6SoM","type":"book","slug":"rom","label":"Romans","subtitle":"Pauline Epistles","count":433,"description":"16 chapters, 238 people, 13 places"}},"stats":{"verses":25,"people":5,"places":0,"events":0},"nodes":[{"id":"rec2cddorsDxouJ4k","type":"chapter","group":"focus","label":"Rom.4","slug":"rom_4","score":25},{"id":"recyvIyxRMFob6SoM","type":"book","group":"book","label":"Romans","slug":"rom","score":433},{"id":"reccdFYIq50NyxNej","type":"person","group":"mentioned","label":"Abraham","slug":"abraham_58","score":7},{"id":"reccZB8SVU5bEMcgo","type":"person","group":"mentioned","label":"God","slug":"god_1324","score":5},{"id":"recgkFqZovgbr3pAi","type":"person","group":"mentioned","label":"Jesus Christ","slug":"jesus_905","score":2},{"id":"rec1ZMFtfbEvoGC73","type":"person","group":"mentioned","label":"David","slug":"david_994","score":1},{"id":"rechda7WMDuW1jBTq","type":"person","group":"mentioned","label":"Sarah","slug":"sarah_2473","score":1}],"links":[{"source":"rec2cddorsDxouJ4k","target":"recyvIyxRMFob6SoM","label":"part of"},{"source":"rec2cddorsDxouJ4k","target":"reccdFYIq50NyxNej","label":"mentions"},{"source":"rec2cddorsDxouJ4k","target":"reccZB8SVU5bEMcgo","label":"mentions"},{"source":"rec2cddorsDxouJ4k","target":"recgkFqZovgbr3pAi","label":"mentions"},{"source":"rec2cddorsDxouJ4k","target":"rec1ZMFtfbEvoGC73","label":"mentions"},{"source":"rec2cddorsDxouJ4k","target":"rechda7WMDuW1jBTq","label":"mentions"}],"verses":[{"id":"reckypybjgBtkrfDm","ref":"Rom.4.1","text":"What shall we say then that Abraham our father, as pertaining to the flesh, hath found?","year":60},{"id":"recSb6XGOqKusbuxn","ref":"Rom.4.2","text":"For if Abraham were justified by works, he hath whereof to glory; but not before God.","year":60},{"id":"reccTGZsQiVV9xru8","ref":"Rom.4.3","text":"For what saith the scripture? Abraham believed God, and it was counted unto him for righteousness.","year":60},{"id":"recGyZshZrcRpbo2C","ref":"Rom.4.4","text":"Now to him that worketh is the reward not reckoned of grace, but of debt.","year":60},{"id":"rec1DrjGr60SHnw38","ref":"Rom.4.5","text":"But to him that worketh not, but believeth on him that justifieth the ungodly, his faith is counted for righteousness.","year":60},{"id":"recYO4n51YPkDDfAx","ref":"Rom.4.6","text":"Even as David also describeth the blessedness of the man, unto whom God imputeth righteousness without works,","year":60},{"id":"reckdU2WmEWjl1HnC","ref":"Rom.4.7","text":"Saying, Blessed are they whose iniquities are forgiven, and whose sins are covered.","year":60},{"id":"recVP0TwwjhIUikEk","ref":"Rom.4.8","text":"Blessed is the man to whom the Lord will not impute sin.","year":60}]}
