{"entity":{"id":"recmOatvxtvuBgAhP","type":"chapter","slug":"recmOatvxtvuBgAhP","label":"Lam.3","rawId":"recmOatvxtvuBgAhP","book":{"id":"recdT4VI6VdkEzixN","type":"book","slug":"lam","label":"Lamentations","subtitle":"Poetry-Wisdom","count":154,"description":"5 chapters, 47 people, 22 places"}},"stats":{"verses":66,"people":1,"places":0,"events":0},"nodes":[{"id":"recmOatvxtvuBgAhP","type":"chapter","group":"focus","label":"Lam.3","slug":"lam_3","score":66},{"id":"recdT4VI6VdkEzixN","type":"book","group":"book","label":"Lamentations","slug":"lam","score":154},{"id":"reccZB8SVU5bEMcgo","type":"person","group":"mentioned","label":"God","slug":"god_1324","score":17}],"links":[{"source":"recmOatvxtvuBgAhP","target":"recdT4VI6VdkEzixN","label":"part of"},{"source":"recmOatvxtvuBgAhP","target":"reccZB8SVU5bEMcgo","label":"mentions"}],"verses":[{"id":"reckti19bNtjYcoLS","ref":"Lam.3.1","text":"I am the man that hath seen affliction by the rod of his wrath.","year":-588},{"id":"rectvSWWEV7Z9HHAq","ref":"Lam.3.2","text":"He hath led me, and brought me into darkness, but not into light.","year":-588},{"id":"recjVcAf9CiETkKRl","ref":"Lam.3.3","text":"Surely against me is he turned; he turneth his hand against me all the day.","year":-588},{"id":"recaoPHjzO2g6X1aU","ref":"Lam.3.4","text":"My flesh and my skin hath he made old; he hath broken my bones.","year":-588},{"id":"recr3zJp0cAs2apsO","ref":"Lam.3.5","text":"He hath builded against me, and compassed me with gall and travail.","year":-588},{"id":"recJa8NVIq8oK8S0o","ref":"Lam.3.6","text":"He hath set me in dark places, as they that be dead of old.","year":-588},{"id":"recKAn7WrBlroPjiS","ref":"Lam.3.7","text":"He hath hedged me about, that I cannot get out: he hath made my chain heavy.","year":-588},{"id":"recLumLzerLhMLrYv","ref":"Lam.3.8","text":"Also when I cry and shout, he shutteth out my prayer.","year":-588}]}
