haalim_1054","score":1},{"id":"recVTeVH1dYATcrWj","type":"place","group":"mentioned","label":"Zuph","slug":"zuph_1276","score":1},{"id":"rec4qaEmaRCFty5tl","type":"event","group":"event","label":"Birth of Saul","slug":"event-150","score":1}],"links":[{"source":"recBzsKYJgF3fBBQD","target":"rec4GS8yWh2R4mpdB","label":"part of"},{"source":"recBzsKYJgF3fBBQD","target":"recjMT68aIzFLh6cQ","label":"mentions"},{"source":"recBzsKYJgF3fBBQD","target":"recZsS2Zu0zIDwqdv","label":"mentions"},{"source":"recBzsKYJgF3fBBQD","target":"reccZB8SVU5bEMcgo","label":"mentions"},{"source":"recBzsKYJgF3fBBQD","target":"recBOUtTncbBlfEn9","label":"mentions"},{"source":"recBzsKYJgF3fBBQD","target":"recz3nyrwezX2XB6C","label":"mentions"},{"source":"recBzsKYJgF3fBBQD","target":"recDC65KH0SDY3HKn","label":"mentions"},{"source":"recBzsKYJgF3fBBQD","target":"recnbkRDy1xp5qzyi","label":"mentions"},{"source":"recBzsKYJgF3fBBQD","target":"recgFYXZmNqvstMCf","label":"mentions"},{"source":"recBzsKYJgF3fBBQD","target":"rec1FwYKXLn4Qf2st","label":"mentions"},{"source":"recBzsKYJgF3fBBQD","target":"recsU2ZSdzBvDqzgI","label":"mentions"},{"source":"recBzsKYJgF3fBBQD","target":"recEtv9ql7Hh4XAW4","label":"mentions"},{"source":"recBzsKYJgF3fBBQD","target":"recNoSjEixSzHZ49q","label":"mentions"},{"source":"recBzsKYJgF3fBBQD","target":"recKFef2G2d4kxjXh","label":"mentions"},{"source":"recBzsKYJgF3fBBQD","target":"recVTeVH1dYATcrWj","label":"mentions"},{"source":"recBzsKYJgF3fBBQD","target":"rec4qaEmaRCFty5tl","label":"event"}],"verses":[{"id":"recXoWkBVPE0ZWlvT","ref":"1Sam.9.1","text":"Now there was a man of Benjamin, whose name was Kish, the son of Abiel, the son of Zeror, the son of Bechorath, the son of Aphiah, a Benjamite, a mighty man of power.","year":-1095},{"id":"recE7bcSz24cRyjo8","ref":"1Sam.9.2","text":"And he had a son, whose name was Saul, a choice young man, and a goodly: and there was not among the children of Israel a goodlier person than he: from his shoulders and upward he was higher than any of the people.","year":-1095},{"id":"reczfsE7WRynp6hgu","ref":"1Sam.9.3","text":"And the asses of Kish Saul’s father were lost. And Kish said to Saul his son, Take now one of the servants with thee, and arise, go seek the asses.","year":-1095},{"id":"recSqadpcA2k6nPOT","ref":"1Sam.9.4","text":"And he passed through mount Ephraim, and passed through the land of Shalisha, but they found them not: then they passed through the land of Shalim, and there they were not: and he passed through the land of the Benjamites, but they found them not.","year":-1095},{"id":"recm420W5SAhIHaWq","ref":"1Sam.9.5","text":"And when they were come to the land of Zuph, Saul said to his servant that was with him, Come, and let us return; lest my father leave caring for the asses, and take thought for us.","year":-1095},{"id":"recJmfuw6NHHRnWna","ref":"1Sam.9.6","text":"And he said unto him, Behold now, there is in this city a man of God, and he is an honourable man; all that he saith cometh surely to pass: now let us go thither; peradventure he can shew us our way that we should go.","year":-1095},{"id":"recOQv1SChKCR7npz","ref":"1Sam.9.7","text":"Then said Saul to his servant, But, behold, if we go, what shall we bring the man? for the bread is spent in our vessels, and there is not a present to bring to the man of God: what have we?","year":-1095},{"id":"recWwS8NUkRboYtRT","ref":"1Sam.9.8","text":"And the servant answered Saul again, and said, Behold, I have here at hand the fourth part of a shekel of silver: that will I give to the man of God, to tell us our way.","year":-1095}]}
