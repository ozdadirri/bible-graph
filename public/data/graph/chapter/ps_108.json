ce":"reciZ371sebxZD5qb","target":"recUySlrBva4ffoVs","label":"mentions"},{"source":"reciZ371sebxZD5qb","target":"recGrj7fktYfxmcbO","label":"mentions"},{"source":"reciZ371sebxZD5qb","target":"recPoImnA7S93jcHx","label":"mentions"},{"source":"reciZ371sebxZD5qb","target":"recirR7tLEeni78L3","label":"mentions"},{"source":"reciZ371sebxZD5qb","target":"recUn6eVJDoG4xI0j","label":"mentions"}],"verses":[{"id":"rec3cZvnzGxTkZuh7","ref":"Ps.108.1","text":"O God, my heart is fixed; I will sing and give praise, even with my glory.","year":-1040},{"id":"recl92fB6tze7bzM2","ref":"Ps.108.2","text":"Awake, psaltery and harp: I myself will awake early.","year":-1040},{"id":"rectflwigpbGTrD5b","ref":"Ps.108.3","text":"I will praise thee, O LORD, among the people: and I will sing praises unto thee among the nations.","year":-1040},{"id":"reci6PmBx2jHAIoxA","ref":"Ps.108.4","text":"For thy mercy is great above the heavens: and thy truth reacheth unto the clouds.","year":-1040},{"id":"receOAViJ4fxXbQjR","ref":"Ps.108.5","text":"Be thou exalted, O God, above the heavens: and thy glory above all the earth;","year":-1040},{"id":"rec7DigMs29WlVw3b","ref":"Ps.108.6","text":"That thy beloved may be delivered: save with thy right hand, and answer me.","year":-1040},{"id":"recKzNHbyvIGmymCI","ref":"Ps.108.7","text":"God hath spoken in his holiness; I will rejoice, I will divide Shechem, and mete out the valley of Succoth.","year":-1040},{"id":"recpUpAld5XAoWdmM","ref":"Ps.108.8","text":"Gilead is mine; Manasseh is mine; Ephraim also is the strength of mine head; Judah is my lawgiver;","year":-1040}]}
