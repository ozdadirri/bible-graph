ource":"recQSFIBpRA5u7fZ1","target":"recb1JorKSXGAF6Vg","label":"mentions"},{"source":"recQSFIBpRA5u7fZ1","target":"recVRtBEdN8mgLhHN","label":"mentions"},{"source":"recQSFIBpRA5u7fZ1","target":"reckJ4vuXzqDbTrMP","label":"mentions"},{"source":"recQSFIBpRA5u7fZ1","target":"reczWOq6vDAOEciY7","label":"mentions"},{"source":"recQSFIBpRA5u7fZ1","target":"recONdJVwpYA57oAi","label":"mentions"},{"source":"recQSFIBpRA5u7fZ1","target":"reco9Wc4YyNXZq43z","label":"mentions"},{"source":"recQSFIBpRA5u7fZ1","target":"recxiSg5QZWkj9Hy3","label":"mentions"},{"source":"recQSFIBpRA5u7fZ1","target":"recAalC2QoLT7cJKN","label":"mentions"},{"source":"recQSFIBpRA5u7fZ1","target":"recL1WV82pXaRBQ59","label":"mentions"},{"source":"recQSFIBpRA5u7fZ1","target":"rec5EydSXHdbLbzk1","label":"event"},{"source":"recQSFIBpRA5u7fZ1","target":"reciGxBNHjPZwHKvO","label":"event"},{"source":"recQSFIBpRA5u7fZ1","target":"recDFt0ANS33dAxri","label":"event"},{"source":"recQSFIBpRA5u7fZ1","target":"recSpTfIckUAeEOLd","label":"event"},{"source":"recQSFIBpRA5u7fZ1","target":"recpYSwD914PD9tHU","label":"event"}],"verses":[{"id":"recIwIfEGUztjXWyH","ref":"Luke.6.1","text":"And it came to pass on the second sabbath after the first, that he went through the corn fields; and his disciples plucked the ears of corn, and did eat, rubbing them in their hands.","year":31},{"id":"recIs4YYxeFEoSJsR","ref":"Luke.6.2","text":"And certain of the Pharisees said unto them, Why do ye that which is not lawful to do on the sabbath days?","year":31},{"id":"recFPZHGbhKv60YeR","ref":"Luke.6.3","text":"And Jesus answering them said, Have ye not read so much as this, what David did, when himself was an hungred, and they which were with him;","year":31},{"id":"rectXYKuO9zPIOMIs","ref":"Luke.6.4","text":"How he went into the house of God, and did take and eat the shewbread, and gave also to them that were with him; which it is not lawful to eat but for the priests alone?","year":31},{"id":"recTY53jTbPqvwcea","ref":"Luke.6.5","text":"And he said unto them, That the Son of man is Lord also of the sabbath.","year":31},{"id":"rec54yh9SnEOaLGxA","ref":"Luke.6.6","text":"And it came to pass also on another sabbath, that he entered into the synagogue and taught: and there was a man whose right hand was withered.","year":31},{"id":"recPuspz6TC0OEHqX","ref":"Luke.6.7","text":"And the scribes and Pharisees watched him, whether he would heal on the sabbath day; that they might find an accusation against him.","year":31},{"id":"recGpnXCTeNc8NbJj","ref":"Luke.6.8","text":"But he knew their thoughts, and said to the man which had the withered hand, Rise up, and stand forth in the midst. And he arose and stood forth.","year":31}]}
