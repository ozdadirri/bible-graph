-aram_916","score":1},{"id":"recUySlrBva4ffoVs","type":"place","group":"mentioned","label":"Shechem","slug":"shechem_1069","score":1}],"links":[{"source":"recp9tGRin6jhkssa","target":"recIFusdNl6d8dj3L","label":"part of"},{"source":"recp9tGRin6jhkssa","target":"recUQWSZuOecG4z1Q","label":"mentions"},{"source":"recp9tGRin6jhkssa","target":"recsU2ZSdzBvDqzgI","label":"mentions"},{"source":"recp9tGRin6jhkssa","target":"recCLJAZbd4JtoMv6","label":"mentions"},{"source":"recp9tGRin6jhkssa","target":"recT2Tm2K5XORGnbx","label":"mentions"},{"source":"recp9tGRin6jhkssa","target":"reccZB8SVU5bEMcgo","label":"mentions"},{"source":"recp9tGRin6jhkssa","target":"rechuDYJoK32gmrME","label":"mentions"},{"source":"recp9tGRin6jhkssa","target":"recfDNqHzhyepDV2z","label":"mentions"},{"source":"recp9tGRin6jhkssa","target":"recGc4mBQC3rOkQ8m","label":"mentions"},{"source":"recp9tGRin6jhkssa","target":"rec695igxX8mX64XC","label":"mentions"},{"source":"recp9tGRin6jhkssa","target":"rec9FmVbRkqnkXn8n","label":"mentions"},{"source":"recp9tGRin6jhkssa","target":"recFcRV7goLrcQm17","label":"mentions"},{"source":"recp9tGRin6jhkssa","target":"recRxBBePxyyV6TFO","label":"mentions"},{"source":"recp9tGRin6jhkssa","target":"recrEteYtMZW1c46t","label":"mentions"},{"source":"recp9tGRin6jhkssa","target":"recUySlrBva4ffoVs","label":"mentions"}],"verses":[{"id":"receZDNBnGrm1A6gh","ref":"Gen.33.1","text":"And Jacob lifted up his eyes, and looked, and, behold, Esau came, and with him four hundred men. And he divided the children unto Leah, and unto Rachel, and unto the two handmaids.","year":-1739},{"id":"rec7V1NG9OPNT9L7W","ref":"Gen.33.2","text":"And he put the handmaids and their children foremost, and Leah and her children after, and Rachel and Joseph hindermost.","year":-1739},{"id":"recuG4l01DjuXUSYg","ref":"Gen.33.3","text":"And he passed over before them, and bowed himself to the ground seven times, until he came near to his brother.","year":-1739},{"id":"recZGFnHJbQz2VTQU","ref":"Gen.33.4","text":"And Esau ran to meet him, and embraced him, and fell on his neck, and kissed him: and they wept.","year":-1739},{"id":"recWSoiqjK3uUp7xF","ref":"Gen.33.5","text":"And he lifted up his eyes, and saw the women and the children; and said, Who are those with thee? And he said, The children which God hath graciously given thy servant.","year":-1739},{"id":"recwEty5lQC33P79S","ref":"Gen.33.6","text":"Then the handmaidens came near, they and their children, and they bowed themselves.","year":-1739},{"id":"recl9Hgak2tIuvQGp","ref":"Gen.33.7","text":"And Leah also with her children came near, and bowed themselves: and after came Joseph near and Rachel, and they bowed themselves.","year":-1739},{"id":"recx5IlL6pfVdaPkp","ref":"Gen.33.8","text":"And he said, What meanest thou by all this drove which I met? And he said, These are to find grace in the sight of my lord.","year":-1739}]}
