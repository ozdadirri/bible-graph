4ksO0H","label":"mentions"},{"source":"recnbBU0mNWzlIIdC","target":"recP6fsKEckt8QTDh","label":"mentions"},{"source":"recnbBU0mNWzlIIdC","target":"reci5XsSfPw9RZWBA","label":"mentions"},{"source":"recnbBU0mNWzlIIdC","target":"recZCo0CjM2eXOicO","label":"mentions"},{"source":"recnbBU0mNWzlIIdC","target":"recGmUGFrSEiOXDnZ","label":"mentions"},{"source":"recnbBU0mNWzlIIdC","target":"recil8ETKDbAGI4uh","label":"mentions"},{"source":"recnbBU0mNWzlIIdC","target":"recUn6eVJDoG4xI0j","label":"mentions"},{"source":"recnbBU0mNWzlIIdC","target":"recR67sC02MfTx4al","label":"mentions"},{"source":"recnbBU0mNWzlIIdC","target":"recpkvM8CHSklH6RP","label":"mentions"},{"source":"recnbBU0mNWzlIIdC","target":"recLcxRZbz3yIQB7b","label":"mentions"},{"source":"recnbBU0mNWzlIIdC","target":"recDWNfN3f6E04V4m","label":"mentions"},{"source":"recnbBU0mNWzlIIdC","target":"recluhQrl8PcgaXJJ","label":"mentions"},{"source":"recnbBU0mNWzlIIdC","target":"recJ0N5yStBk9CjXA","label":"mentions"},{"source":"recnbBU0mNWzlIIdC","target":"recL1WV82pXaRBQ59","label":"mentions"},{"source":"recnbBU0mNWzlIIdC","target":"receUGVTCDMBusNhW","label":"mentions"},{"source":"recnbBU0mNWzlIIdC","target":"rec871Urh3FpMXS3G","label":"mentions"}],"verses":[{"id":"recL0NgNHAjQ3HdUn","ref":"1Chr.18.1","text":"Now after this it came to pass, that David smote the Philistines, and subdued them, and took Gath and her towns out of the hand of the Philistines.","year":-1040},{"id":"recmctrtPLQWIusam","ref":"1Chr.18.2","text":"And he smote Moab; and the Moabites became David’s servants, and brought gifts.","year":-1040},{"id":"recU9tQ7Qr3mM8mYb","ref":"1Chr.18.3","text":"And David smote Hadarezer king of Zobah unto Hamath, as he went to stablish his dominion by the river Euphrates.","year":-1040},{"id":"recS6wvyGAnTYLl1V","ref":"1Chr.18.4","text":"And David took from him a thousand chariots, and seven thousand horsemen, and twenty thousand footmen: David also houghed all the chariot horses, but reserved of them an hundred chariots.","year":-1040},{"id":"recwC3EBgvAvxybHF","ref":"1Chr.18.5","text":"And when the Syrians of Damascus came to help Hadarezer king of Zobah, David slew of the Syrians two and twenty thousand men.","year":-1040},{"id":"recWLJapMn2p9SQgQ","ref":"1Chr.18.6","text":"Then David put garrisons in Syriadamascus; and the Syrians became David’s servants, and brought gifts. Thus the LORD preserved David whithersoever he went.","year":-1040},{"id":"recOpieQI64vlZEEU","ref":"1Chr.18.7","text":"And David took the shields of gold that were on the servants of Hadarezer, and brought them to Jerusalem.","year":-1040},{"id":"rec6dpaVawzBQF5cz","ref":"1Chr.18.8","text":"Likewise from Tibhath, and from Chun, cities of Hadarezer, brought David very much brass, wherewith Solomon made the brasen sea, and the pillars, and the vessels of brass.","year":-1040}]}
