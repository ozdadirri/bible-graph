{"entity":{"id":"rec9wlOhUqQwo4nZh","type":"chapter","slug":"rec9wlOhUqQwo4nZh","label":"Job.6","rawId":"rec9wlOhUqQwo4nZh","book":{"id":"recOA8nVVhKs30PSI","type":"book","slug":"job","label":"Job","subtitle":"Poetry-Wisdom","count":1070,"description":"42 chapters, 190 people, 6 places"}},"stats":{"verses":30,"people":2,"places":2,"events":1},"nodes":[{"id":"rec9wlOhUqQwo4nZh","type":"chapter","group":"focus","label":"Job.6","slug":"job_6","score":30},{"id":"recOA8nVVhKs30PSI","type":"book","group":"book","label":"Job","slug":"job","score":1070},{"id":"reccZB8SVU5bEMcgo","type":"person","group":"mentioned","label":"God","slug":"god_1324","score":5},{"id":"recKXL1QrW8qTw5Ux","type":"person","group":"mentioned","label":"Job","slug":"job_1639","score":1},{"id":"recrydf4wCTnlOHEO","type":"place","group":"mentioned","label":"Tema","slug":"tema_1149","score":1},{"id":"recPLjuDonDk53ED5","type":"place","group":"mentioned","label":"Sheba","slug":"sheba_1067","score":1},{"id":"recMNT9RB1RJiLlYW","type":"event","group":"event","label":"Job's Trial","slug":"event-117","score":30}],"links":[{"source":"rec9wlOhUqQwo4nZh","target":"recOA8nVVhKs30PSI","label":"part of"},{"source":"rec9wlOhUqQwo4nZh","target":"reccZB8SVU5bEMcgo","label":"mentions"},{"source":"rec9wlOhUqQwo4nZh","target":"recKXL1QrW8qTw5Ux","label":"mentions"},{"source":"rec9wlOhUqQwo4nZh","target":"recrydf4wCTnlOHEO","label":"mentions"},{"source":"rec9wlOhUqQwo4nZh","target":"recPLjuDonDk53ED5","label":"mentions"},{"source":"rec9wlOhUqQwo4nZh","target":"recMNT9RB1RJiLlYW","label":"event"}],"verses":[{"id":"recFcCarzyHVyrGQw","ref":"Job.6.1","text":"But Job answered and said,","year":-1520},{"id":"rece7vuiR2uYZxk7K","ref":"Job.6.2","text":"Oh that my grief were throughly weighed, and my calamity laid in the balances together!","year":-1520},{"id":"recC1D7a7NdDQ7Wa0","ref":"Job.6.3","text":"For now it would be heavier than the sand of the sea: therefore my words are swallowed up.","year":-1520},{"id":"recMlE3zLQrArqOEn","ref":"Job.6.4","text":"For the arrows of the Almighty are within me, the poison whereof drinketh up my spirit: the terrors of God do set themselves in array against me.","year":-1520},{"id":"recxYjiq4h96z6QAM","ref":"Job.6.5","text":"Doth the wild ass bray when he hath grass? or loweth the ox over his fodder?","year":-1520},{"id":"recgrsSXJj5wbywV1","ref":"Job.6.6","text":"Can that which is unsavoury be eaten without salt? or is there any taste in the white of an egg?","year":-1520},{"id":"recZAbqmrXDMCDvIH","ref":"Job.6.7","text":"The things that my soul refused to touch are as my sorrowful meat.","year":-1520},{"id":"rec1HSSYdqLX5rvzS","ref":"Job.6.8","text":"Oh that I might have my request; and that God would grant me the thing that I long for!","year":-1520}]}
