":"recT72h6teUyP1SLL","label":"mentions"},{"source":"recFw3O8sdfrkhvg8","target":"recrbd7DEzjHDamsf","label":"mentions"},{"source":"recFw3O8sdfrkhvg8","target":"recOXtCZgcG7YobCm","label":"mentions"},{"source":"recFw3O8sdfrkhvg8","target":"recdIZxgxO61iLEXm","label":"mentions"},{"source":"recFw3O8sdfrkhvg8","target":"recyDlo13a3T5DDGh","label":"mentions"}],"verses":[{"id":"recIcrx0RDtrsMNgl","ref":"Num.4.1","text":"And the LORD spake unto Moses and unto Aaron, saying,","year":-1490},{"id":"rec36KAvGTU520jNX","ref":"Num.4.2","text":"Take the sum of the sons of Kohath from among the sons of Levi, after their families, by the house of their fathers,","year":-1490},{"id":"recn7xXmhQcwpZiMu","ref":"Num.4.3","text":"From thirty years old and upward even until fifty years old, all that enter into the host, to do the work in the tabernacle of the congregation.","year":-1490},{"id":"recZRDRhB2nexkRdC","ref":"Num.4.4","text":"This shall be the service of the sons of Kohath in the tabernacle of the congregation, about the most holy things:","year":-1490},{"id":"rec5W4HDh0UDpEd3S","ref":"Num.4.5","text":"And when the camp setteth forward, Aaron shall come, and his sons, and they shall take down the covering vail, and cover the ark of testimony with it:","year":-1490},{"id":"recVYPINFOiKtI2s9","ref":"Num.4.6","text":"And shall put thereon the covering of badgers’ skins, and shall spread over it a cloth wholly of blue, and shall put in the staves thereof.","year":-1490},{"id":"recplAQc4hkoOBimF","ref":"Num.4.7","text":"And upon the table of shewbread they shall spread a cloth of blue, and put thereon the dishes, and the spoons, and the bowls, and covers to cover withal: and the continual bread shall be thereon:","year":-1490},{"id":"recHiMf8rWg1fIGY4","ref":"Num.4.8","text":"And they shall spread upon them a cloth of scarlet, and cover the same with a covering of badgers’ skins, and shall put in the staves thereof.","year":-1490}]}
