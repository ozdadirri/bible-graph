lug":"midian_796","score":1},{"id":"recEP3QZ3HUmIkv4Q","type":"place","group":"mentioned","label":"Samaria","slug":"samaria_1022","score":1},{"id":"recQ1bj3p4Lj5MYY6","type":"event","group":"event","label":"Prophecies of Isaiah","slug":"event-217","score":21}],"links":[{"source":"recXm5cOVePIJv7yl","target":"recr2ic6Ws3R14a5I","label":"part of"},{"source":"recXm5cOVePIJv7yl","target":"reccZB8SVU5bEMcgo","label":"mentions"},{"source":"recXm5cOVePIJv7yl","target":"recEtv9ql7Hh4XAW4","label":"mentions"},{"source":"recXm5cOVePIJv7yl","target":"recZ6YiBydClBiVVJ","label":"mentions"},{"source":"recXm5cOVePIJv7yl","target":"recmAUAIwW85ajksn","label":"mentions"},{"source":"recXm5cOVePIJv7yl","target":"recuAalSpGhVahIhx","label":"mentions"},{"source":"recXm5cOVePIJv7yl","target":"recgkFqZovgbr3pAi","label":"mentions"},{"source":"recXm5cOVePIJv7yl","target":"rec1ZMFtfbEvoGC73","label":"mentions"},{"source":"recXm5cOVePIJv7yl","target":"recsU2ZSdzBvDqzgI","label":"mentions"},{"source":"recXm5cOVePIJv7yl","target":"rec1nwxpOMQgGsW7C","label":"mentions"},{"source":"recXm5cOVePIJv7yl","target":"rec1YbscOE9IyJ5ey","label":"mentions"},{"source":"recXm5cOVePIJv7yl","target":"rec5dSSsOutWlH2fW","label":"mentions"},{"source":"recXm5cOVePIJv7yl","target":"recmL1lWBqWP3mAq3","label":"mentions"},{"source":"recXm5cOVePIJv7yl","target":"recBZhqAvy5xhTNRn","label":"mentions"},{"source":"recXm5cOVePIJv7yl","target":"recEP3QZ3HUmIkv4Q","label":"mentions"},{"source":"recXm5cOVePIJv7yl","target":"recQ1bj3p4Lj5MYY6","label":"event"}],"verses":[{"id":"reco1uePW5NfandA9","ref":"Isa.9.1","text":"Nevertheless the dimness shall not be such as was in her vexation, when at the first he lightly afflicted the land of Zebulun and the land of Naphtali, and afterward did more grievously afflict her by the way of the sea, beyond Jordan, in Galilee of the nations.","year":-740},{"id":"recapY1brytYo3g7s","ref":"Isa.9.2","text":"The people that walked in darkness have seen a great light: they that dwell in the land of the shadow of death, upon them hath the light shined.","year":-740},{"id":"recHcES9OX5Y5jRvS","ref":"Isa.9.3","text":"Thou hast multiplied the nation, and not increased the joy: they joy before thee according to the joy in harvest, and as men rejoice when they divide the spoil.","year":-740},{"id":"rec6iiJkBpZ8iN2Zb","ref":"Isa.9.4","text":"For thou hast broken the yoke of his burden, and the staff of his shoulder, the rod of his oppressor, as in the day of Midian.","year":-740},{"id":"recgzBUPRXfNJ9I9M","ref":"Isa.9.5","text":"For every battle of the warrior is with confused noise, and garments rolled in blood; but this shall be with burning and fuel of fire.","year":-740},{"id":"rec5b41aM6T6rz6cK","ref":"Isa.9.6","text":"For unto us a child is born, unto us a son is given: and the government shall be upon his shoulder: and his name shall be called Wonderful, Counsellor, The mighty God, The everlasting Father, The Prince of Peace.","year":-740},{"id":"rec6grfWkVuKJzkSt","ref":"Isa.9.7","text":"Of the increase of his government and peace there shall be no end, upon the throne of David, and upon his kingdom, to order it, and to establish it with judgment and with justice from henceforth even for ever. The zeal of the LORD of hosts will perform this.","year":-740},{"id":"recgrgHgRKghMZFKL","ref":"Isa.9.8","text":"The Lord sent a word into Jacob, and it hath lighted upon Israel.","year":-740}]}
