{"entity":{"id":"rec3T7sPe99m1QTlu","type":"chapter","slug":"rec3T7sPe99m1QTlu","label":"Ps.99","rawId":"rec3T7sPe99m1QTlu","book":{"id":"recKXZXO6cJwk2SxO","type":"book","slug":"ps","label":"Psalms","subtitle":"Poetry-Wisdom","count":2461,"description":"150 chapters, 1026 people, 118 places"}},"stats":{"verses":9,"people":5,"places":1,"events":0},"nodes":[{"id":"rec3T7sPe99m1QTlu","type":"chapter","group":"focus","label":"Ps.99","slug":"ps_99","score":9},{"id":"recKXZXO6cJwk2SxO","type":"book","group":"book","label":"Psalms","slug":"ps","score":2461},{"id":"reccZB8SVU5bEMcgo","type":"person","group":"mentioned","label":"God","slug":"god_1324","score":6},{"id":"recsU2ZSdzBvDqzgI","type":"person","group":"mentioned","label":"Jacob (Israel)","slug":"israel_682","score":1},{"id":"recjNRR60PAuFtjha","type":"person","group":"mentioned","label":"Moses","slug":"moses_2108","score":1},{"id":"recv0dAY2ULzJ687g","type":"person","group":"mentioned","label":"Aaron","slug":"aaron_1","score":1},{"id":"recZsS2Zu0zIDwqdv","type":"person","group":"mentioned","label":"Samuel","slug":"samuel_2469","score":1},{"id":"reczPjeq0UdahiRrn","type":"place","group":"mentioned","label":"Zion","slug":"zion_1263","score":1}],"links":[{"source":"rec3T7sPe99m1QTlu","target":"recKXZXO6cJwk2SxO","label":"part of"},{"source":"rec3T7sPe99m1QTlu","target":"reccZB8SVU5bEMcgo","label":"mentions"},{"source":"rec3T7sPe99m1QTlu","target":"recsU2ZSdzBvDqzgI","label":"mentions"},{"source":"rec3T7sPe99m1QTlu","target":"recjNRR60PAuFtjha","label":"mentions"},{"source":"rec3T7sPe99m1QTlu","target":"recv0dAY2ULzJ687g","label":"mentions"},{"source":"rec3T7sPe99m1QTlu","target":"recZsS2Zu0zIDwqdv","label":"mentions"},{"source":"rec3T7sPe99m1QTlu","target":"reczPjeq0UdahiRrn","label":"mentions"}],"verses":[{"id":"rec6U323VGEBULAym","ref":"Ps.99.1","text":"The LORD reigneth; let the people tremble: he sitteth between the cherubims; let the earth be moved."},{"id":"recMnZgZf7XmiCnTm","ref":"Ps.99.2","text":"The LORD is great in Zion; and he is high above all the people."},{"id":"recWhJyQi7NHT8ueB","ref":"Ps.99.3","text":"Let them praise thy great and terrible name; for it is holy."},{"id":"rec31bXSGb22QVjFI","ref":"Ps.99.4","text":"The king’s strength also loveth judgment; thou dost establish equity, thou executest judgment and righteousness in Jacob."},{"id":"recZXgUsJkFp7z974","ref":"Ps.99.5","text":"Exalt ye the LORD our God, and worship at his footstool; for he is holy."},{"id":"recMULiMFc1dBYuTl","ref":"Ps.99.6","text":"Moses and Aaron among his priests, and Samuel among them that call upon his name; they called upon the LORD, and he answered them."},{"id":"rectKU2g7vupoBuxT","ref":"Ps.99.7","text":"He spake unto them in the cloudy pillar: they kept his testimonies, and the ordinance that he gave them."},{"id":"recc6DIRLKdSPg7gG","ref":"Ps.99.8","text":"Thou answeredst them, O LORD our God: thou wast a God that forgavest them, though thou tookest vengeance of their inventions."}]}
