{"entity":{"id":"recXWoDEKZzXffTEQ","type":"chapter","slug":"recXWoDEKZzXffTEQ","label":"Ps.109","rawId":"recXWoDEKZzXffTEQ","book":{"id":"recKXZXO6cJwk2SxO","type":"book","slug":"ps","label":"Psalms","subtitle":"Poetry-Wisdom","count":2461,"description":"150 chapters, 1026 people, 118 places"}},"stats":{"verses":31,"people":2,"places":0,"events":0},"nodes":[{"id":"recXWoDEKZzXffTEQ","type":"chapter","group":"focus","label":"Ps.109","slug":"ps_109","score":31},{"id":"recKXZXO6cJwk2SxO","type":"book","group":"book","label":"Psalms","slug":"ps","score":2461},{"id":"reccZB8SVU5bEMcgo","type":"person","group":"mentioned","label":"God","slug":"god_1324","score":8},{"id":"recLFwe2uKBqJwmWn","type":"person","group":"mentioned","label":"Satan","slug":"satan_2476","score":1}],"links":[{"source":"recXWoDEKZzXffTEQ","target":"recKXZXO6cJwk2SxO","label":"part of"},{"source":"recXWoDEKZzXffTEQ","target":"reccZB8SVU5bEMcgo","label":"mentions"},{"source":"recXWoDEKZzXffTEQ","target":"recLFwe2uKBqJwmWn","label":"mentions"}],"verses":[{"id":"receT1CoLHeeAO8Pq","ref":"Ps.109.1","text":"Hold not thy peace, O God of my praise;","year":-1062},{"id":"recRcayTG6Ylqc027","ref":"Ps.109.2","text":"For the mouth of the wicked and the mouth of the deceitful are opened against me: they have spoken against me with a lying tongue.","year":-1062},{"id":"recghEVMjOK8sc8vH","ref":"Ps.109.3","text":"They compassed me about also with words of hatred; and fought against me without a cause.","year":-1062},{"id":"recl1zmzRgn5yZlvC","ref":"Ps.109.4","text":"For my love they are my adversaries: but I give myself unto prayer.","year":-1062},{"id":"recNEHIt3XbLymfxd","ref":"Ps.109.5","text":"And they have rewarded me evil for good, and hatred for my love.","year":-1062},{"id":"recKsr22x0R8JstZe","ref":"Ps.109.6","text":"Set thou a wicked man over him: and let Satan stand at his right hand.","year":-1062},{"id":"recw9WPwHYjKQkpEV","ref":"Ps.109.7","text":"When he shall be judged, let him be condemned: and let his prayer become sin.","year":-1062},{"id":"recV172xBSO2tGINy","ref":"Ps.109.8","text":"Let his days be few; and let another take his office.","year":-1062}]}
