SLiiWH8fM","target":"recquAR8Sw42aohg7","label":"mentions"},{"source":"recRTadhSLiiWH8fM","target":"recrRAVkDKZCXTSl7","label":"mentions"},{"source":"recRTadhSLiiWH8fM","target":"recH9ECLXz8IgSUgF","label":"mentions"},{"source":"recRTadhSLiiWH8fM","target":"recBOUtTncbBlfEn9","label":"mentions"},{"source":"recRTadhSLiiWH8fM","target":"recsU2ZSdzBvDqzgI","label":"mentions"},{"source":"recRTadhSLiiWH8fM","target":"recEtv9ql7Hh4XAW4","label":"mentions"},{"source":"recRTadhSLiiWH8fM","target":"rec3qiPi8JN2h86Mj","label":"mentions"},{"source":"recRTadhSLiiWH8fM","target":"recADz5cMmoTWAEzV","label":"mentions"},{"source":"recRTadhSLiiWH8fM","target":"recHdRjsxQjhsjW3i","label":"mentions"},{"source":"recRTadhSLiiWH8fM","target":"recT8QZtq4sQBftmu","label":"mentions"},{"source":"recRTadhSLiiWH8fM","target":"recPt1Ig1xZkj2YWS","label":"mentions"},{"source":"recRTadhSLiiWH8fM","target":"rechDks6lIaQnH21X","label":"mentions"},{"source":"recRTadhSLiiWH8fM","target":"recHY6HweDEcJC6v0","label":"mentions"},{"source":"recRTadhSLiiWH8fM","target":"recgAmwf1FZDe8DST","label":"mentions"},{"source":"recRTadhSLiiWH8fM","target":"recAW3NovSbgdfNfk","label":"mentions"},{"source":"recRTadhSLiiWH8fM","target":"recpkvM8CHSklH6RP","label":"mentions"},{"source":"recRTadhSLiiWH8fM","target":"recUn6eVJDoG4xI0j","label":"mentions"},{"source":"recRTadhSLiiWH8fM","target":"recKRsEFLaEueJvei","label":"event"}],"verses":[{"id":"recc4jtcKnxtFirZG","ref":"1Sam.14.1","text":"Now it came to pass upon a day, that Jonathan the son of Saul said unto the young man that bare his armour, Come, and let us go over to the Philistines’ garrison, that is on the other side. But he told not his father.","year":-1087},{"id":"recOMqssmi3mRCbPg","ref":"1Sam.14.2","text":"And Saul tarried in the uttermost part of Gibeah under a pomegranate tree which is in Migron: and the people that were with him were about six hundred men;","year":-1087},{"id":"recX0E5P8ymvZn11i","ref":"1Sam.14.3","text":"And Ahiah, the son of Ahitub, Ichabod’s brother, the son of Phinehas, the son of Eli, the LORD’S priest in Shiloh, wearing an ephod. And the people knew not that Jonathan was gone.","year":-1087},{"id":"recyLyDeWXhsBMgR9","ref":"1Sam.14.4","text":"And between the passages, by which Jonathan sought to go over unto the Philistines’ garrison, there was a sharp rock on the one side, and a sharp rock on the other side: and the name of the one was Bozez, and the name of the other Seneh.","year":-1087},{"id":"rec4BhPukzd0sNmFI","ref":"1Sam.14.5","text":"The forefront of the one was situate northward over against Michmash, and the other southward over against Gibeah.","year":-1087},{"id":"recSvEYFxlOOPJQ8G","ref":"1Sam.14.6","text":"And Jonathan said to the young man that bare his armour, Come, and let us go over unto the garrison of these uncircumcised: it may be that the LORD will work for us: for there is no restraint to the LORD to save by many or by few.","year":-1087},{"id":"rec1RaTB1rXb1cbKg","ref":"1Sam.14.7","text":"And his armourbearer said unto him, Do all that is in thine heart: turn thee; behold, I am with thee according to thy heart.","year":-1087},{"id":"rec43UBhODcnV5MkX","ref":"1Sam.14.8","text":"Then said Jonathan, Behold, we will pass over unto these men, and we will discover ourselves unto them.","year":-1087}]}
