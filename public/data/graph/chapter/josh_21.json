dyROZogTq","target":"recjNRR60PAuFtjha","label":"mentions"},{"source":"recHWwuAdyROZogTq","target":"recjDsafRYaksAqa1","label":"mentions"},{"source":"recHWwuAdyROZogTq","target":"recBOUtTncbBlfEn9","label":"mentions"},{"source":"recHWwuAdyROZogTq","target":"recwqzXQjpmdyyW9y","label":"mentions"},{"source":"recHWwuAdyROZogTq","target":"recx0o0Q5Ekmf6zFv","label":"mentions"},{"source":"recHWwuAdyROZogTq","target":"rec3HzZknu1HOvNci","label":"mentions"},{"source":"recHWwuAdyROZogTq","target":"recgdvRbWEPMp5I0z","label":"mentions"},{"source":"recHWwuAdyROZogTq","target":"recJSfVnIcPibY6aX","label":"mentions"},{"source":"recHWwuAdyROZogTq","target":"recPt1Ig1xZkj2YWS","label":"mentions"},{"source":"recHWwuAdyROZogTq","target":"recRxBBePxyyV6TFO","label":"mentions"},{"source":"recHWwuAdyROZogTq","target":"rec5g1fzEKYzCO1Re","label":"mentions"},{"source":"recHWwuAdyROZogTq","target":"recaKtNNdTaSwmzoB","label":"mentions"},{"source":"recHWwuAdyROZogTq","target":"recNvVf6oxrh2Aqhe","label":"mentions"},{"source":"recHWwuAdyROZogTq","target":"rec76ox1jwnhFHmzl","label":"mentions"},{"source":"recHWwuAdyROZogTq","target":"reclzdXLmXHPKYAou","label":"mentions"},{"source":"recHWwuAdyROZogTq","target":"recocNih6Mr5ISN1d","label":"mentions"}],"verses":[{"id":"recnolph8hQwKtFZ6","ref":"Josh.21.1","text":"Then came near the heads of the fathers of the Levites unto Eleazar the priest, and unto Joshua the son of Nun, and unto the heads of the fathers of the tribes of the children of Israel;","year":-1443},{"id":"recLoNZhRsz7gBbcZ","ref":"Josh.21.2","text":"And they spake unto them at Shiloh in the land of Canaan, saying, The LORD commanded by the hand of Moses to give us cities to dwell in, with the suburbs thereof for our cattle.","year":-1443},{"id":"recJ00d4q0HHLkEjI","ref":"Josh.21.3","text":"And the children of Israel gave unto the Levites out of their inheritance, at the commandment of the LORD, these cities and their suburbs.","year":-1443},{"id":"recAGedGm4nUKQRhF","ref":"Josh.21.4","text":"And the lot came out for the families of the Kohathites: and the children of Aaron the priest, which were of the Levites, had by lot out of the tribe of Judah, and out of the tribe of Simeon, and out of the tribe of Benjamin, thirteen cities.","year":-1443},{"id":"rec3NgLy8T8Mds2bX","ref":"Josh.21.5","text":"And the rest of the children of Kohath had by lot out of the families of the tribe of Ephraim, and out of the tribe of Dan, and out of the half tribe of Manasseh, ten cities.","year":-1443},{"id":"rec3zYPc4knrQf1iH","ref":"Josh.21.6","text":"And the children of Gershon had by lot out of the families of the tribe of Issachar, and out of the tribe of Asher, and out of the tribe of Naphtali, and out of the half tribe of Manasseh in Bashan, thirteen cities.","year":-1443},{"id":"recAqcPJAYq77oKIo","ref":"Josh.21.7","text":"The children of Merari by their families had out of the tribe of Reuben, and out of the tribe of Gad, and out of the tribe of Zebulun, twelve cities.","year":-1443},{"id":"recNKutzTN2IkVDpW","ref":"Josh.21.8","text":"And the children of Israel gave by lot unto the Levites these cities with their suburbs, as the LORD commanded by the hand of Moses.","year":-1443}]}
