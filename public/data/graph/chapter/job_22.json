{"entity":{"id":"recC9xHsTGu2j4p2W","type":"chapter","slug":"recC9xHsTGu2j4p2W","label":"Job.22","rawId":"recC9xHsTGu2j4p2W","book":{"id":"recOA8nVVhKs30PSI","type":"book","slug":"job","label":"Job","subtitle":"Poetry-Wisdom","count":1070,"description":"42 chapters, 190 people, 6 places"}},"stats":{"verses":30,"people":2,"places":1,"events":1},"nodes":[{"id":"recC9xHsTGu2j4p2W","type":"chapter","group":"focus","label":"Job.22","slug":"job_22","score":30},{"id":"recOA8nVVhKs30PSI","type":"book","group":"book","label":"Job","slug":"job","score":1070},{"id":"reccZB8SVU5bEMcgo","type":"person","group":"mentioned","label":"God","slug":"god_1324","score":8},{"id":"recE1c6dLNGYPFRiW","type":"person","group":"mentioned","label":"Eliphaz","slug":"eliphaz_1145","score":1},{"id":"recPkpwSKDIF9jQ3T","type":"place","group":"mentioned","label":"Ophir","slug":"ophir_911","score":1},{"id":"recMNT9RB1RJiLlYW","type":"event","group":"event","label":"Job's Trial","slug":"event-117","score":30}],"links":[{"source":"recC9xHsTGu2j4p2W","target":"recOA8nVVhKs30PSI","label":"part of"},{"source":"recC9xHsTGu2j4p2W","target":"reccZB8SVU5bEMcgo","label":"mentions"},{"source":"recC9xHsTGu2j4p2W","target":"recE1c6dLNGYPFRiW","label":"mentions"},{"source":"recC9xHsTGu2j4p2W","target":"recPkpwSKDIF9jQ3T","label":"mentions"},{"source":"recC9xHsTGu2j4p2W","target":"recMNT9RB1RJiLlYW","label":"event"}],"verses":[{"id":"recWgLnVPyMDPkIMU","ref":"Job.22.1","text":"Then Eliphaz the Temanite answered and said,","year":-1520},{"id":"recqWtAytOQic9xNL","ref":"Job.22.2","text":"Can a man be profitable unto God, as he that is wise may be profitable unto himself?","year":-1520},{"id":"recXJlV5DNXI5yxwC","ref":"Job.22.3","text":"Is it any pleasure to the Almighty, that thou art righteous? or is it gain to him, that thou makest thy ways perfect?","year":-1520},{"id":"recZ6XMcYoiO538gW","ref":"Job.22.4","text":"Will he reprove thee for fear of thee? will he enter with thee into judgment?","year":-1520},{"id":"recGfnjdSj6M1UDA6","ref":"Job.22.5","text":"Is not thy wickedness great? and thine iniquities infinite?","year":-1520},{"id":"recxmvlYXQHK9H5he","ref":"Job.22.6","text":"For thou hast taken a pledge from thy brother for nought, and stripped the naked of their clothing.","year":-1520},{"id":"recdBmaolDPVuucBt","ref":"Job.22.7","text":"Thou hast not given water to the weary to drink, and thou hast withholden bread from the hungry.","year":-1520},{"id":"recBnxXtcxdX1zwx7","ref":"Job.22.8","text":"But as for the mighty man, he had the earth; and the honourable man dwelt in it.","year":-1520}]}
