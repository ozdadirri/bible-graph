oJWFIz7","target":"rec5XS12X23Uadj5G","label":"mentions"},{"source":"recVZx7zfsoJWFIz7","target":"recuiNskL8Wft4eRh","label":"mentions"},{"source":"recVZx7zfsoJWFIz7","target":"recNSkNykAbbf9sRg","label":"mentions"},{"source":"recVZx7zfsoJWFIz7","target":"recpCMN0bRpzByjaR","label":"mentions"},{"source":"recVZx7zfsoJWFIz7","target":"recbCU03lFSJIIVGi","label":"mentions"}],"verses":[{"id":"reczkrSRLt8qSAS10","ref":"1Pet.1.1","text":"Peter, an apostle of Jesus Christ, to the strangers scattered throughout Pontus, Galatia, Cappadocia, Asia, and Bithynia,","year":60},{"id":"rech39ZNy4AjmkX7E","ref":"1Pet.1.2","text":"Elect according to the foreknowledge of God the Father, through sanctification of the Spirit, unto obedience and sprinkling of the blood of Jesus Christ: Grace unto you, and peace, be multiplied.","year":60},{"id":"recqlupykLwDKAEHn","ref":"1Pet.1.3","text":"Blessed be the God and Father of our Lord Jesus Christ, which according to his abundant mercy hath begotten us again unto a lively hope by the resurrection of Jesus Christ from the dead,","year":60},{"id":"recH4GpvmXGBxzE5X","ref":"1Pet.1.4","text":"To an inheritance incorruptible, and undefiled, and that fadeth not away, reserved in heaven for you,","year":60},{"id":"recZtHBOT6zfxAOza","ref":"1Pet.1.5","text":"Who are kept by the power of God through faith unto salvation ready to be revealed in the last time.","year":60},{"id":"recChaqoe4cE5v3d0","ref":"1Pet.1.6","text":"Wherein ye greatly rejoice, though now for a season, if need be, ye are in heaviness through manifold temptations:","year":60},{"id":"rec09GXN18no69Xcc","ref":"1Pet.1.7","text":"That the trial of your faith, being much more precious than of gold that perisheth, though it be tried with fire, might be found unto praise and honour and glory at the appearing of Jesus Christ:","year":60},{"id":"recZ893nqW8s3IA8R","ref":"1Pet.1.8","text":"Whom having not seen, ye love; in whom, though now ye see him not, yet believing, ye rejoice with joy unspeakable and full of glory:","year":60}]}
