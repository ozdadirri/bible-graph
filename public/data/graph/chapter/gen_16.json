IOSmMQDB6z","target":"reccdFYIq50NyxNej","label":"mentions"},{"source":"recwo9DIOSmMQDB6z","target":"reccZB8SVU5bEMcgo","label":"mentions"},{"source":"recwo9DIOSmMQDB6z","target":"rechda7WMDuW1jBTq","label":"mentions"},{"source":"recwo9DIOSmMQDB6z","target":"recL1zd3NT68owBAG","label":"mentions"},{"source":"recwo9DIOSmMQDB6z","target":"recvV3hxT3VINGuwx","label":"mentions"},{"source":"recwo9DIOSmMQDB6z","target":"recGc4mBQC3rOkQ8m","label":"mentions"},{"source":"recwo9DIOSmMQDB6z","target":"recRxBBePxyyV6TFO","label":"mentions"},{"source":"recwo9DIOSmMQDB6z","target":"recKc1ulr0DPuFTnO","label":"mentions"},{"source":"recwo9DIOSmMQDB6z","target":"recbFkcAeBmrPDZvG","label":"mentions"},{"source":"recwo9DIOSmMQDB6z","target":"recrLh8m0GOwaWHsf","label":"mentions"},{"source":"recwo9DIOSmMQDB6z","target":"rechXJhZerr2X4BnE","label":"event"},{"source":"recwo9DIOSmMQDB6z","target":"rec1CnwQbgxnwGiRS","label":"event"}],"verses":[{"id":"recCdmpkKJp3mpK70","ref":"Gen.16.1","text":"Now Sarai Abram’s wife bare him no children: and she had an handmaid, an Egyptian, whose name was Hagar.","year":-1912},{"id":"recoEVd9glIcL8jo2","ref":"Gen.16.2","text":"And Sarai said unto Abram, Behold now, the LORD hath restrained me from bearing: I pray thee, go in unto my maid; it may be that I may obtain children by her. And Abram hearkened to the voice of Sarai.","year":-1912},{"id":"rec40N0VRxv1rfoq6","ref":"Gen.16.3","text":"And Sarai Abram’s wife took Hagar her maid the Egyptian, after Abram had dwelt ten years in the land of Canaan, and gave her to her husband Abram to be his wife.","year":-1911},{"id":"recu87ctmwBDM8S1J","ref":"Gen.16.4","text":"And he went in unto Hagar, and she conceived: and when she saw that she had conceived, her mistress was despised in her eyes.","year":-1911},{"id":"recWLqEf5OOHqYoXj","ref":"Gen.16.5","text":"And Sarai said unto Abram, My wrong be upon thee: I have given my maid into thy bosom; and when she saw that she had conceived, I was despised in her eyes: the LORD judge between me and thee.","year":-1911},{"id":"recNgCd4ZZzGZWPGi","ref":"Gen.16.6","text":"But Abram said unto Sarai, Behold, thy maid is in thy hand; do to her as it pleaseth thee. And when Sarai dealt hardly with her, she fled from her face.","year":-1911},{"id":"recsSK02sVdfmlJqk","ref":"Gen.16.7","text":"And the angel of the LORD found her by a fountain of water in the wilderness, by the fountain in the way to Shur.","year":-1911},{"id":"recMzhbWygCBCsFIf","ref":"Gen.16.8","text":"And he said, Hagar, Sarai’s maid, whence camest thou? and whither wilt thou go? And she said, I flee from the face of my mistress Sarai.","year":-1911}]}
