ype":"place","group":"mentioned","label":"Assyria","slug":"assyria_111","score":1},{"id":"recppjCaJndWnPp96","type":"place","group":"mentioned","label":"Fish Gate","slug":"fish_gate_426","score":1},{"id":"recIF1Q0gHP65ziSy","type":"place","group":"mentioned","label":"Ophel","slug":"ophel_910","score":1},{"id":"recOW0FKyYhhTt7vV","type":"place","group":"mentioned","label":"Gihon","slug":"gihon_473","score":1}],"links":[{"source":"reckTSwmGnaNloYcH","target":"rec410yOewjNfbeE3","label":"part of"},{"source":"reckTSwmGnaNloYcH","target":"reccZB8SVU5bEMcgo","label":"mentions"},{"source":"reckTSwmGnaNloYcH","target":"rec5LjGfCEP8klGHt","label":"mentions"},{"source":"reckTSwmGnaNloYcH","target":"rectyCDQXPV0r8tal","label":"mentions"},{"source":"reckTSwmGnaNloYcH","target":"recsU2ZSdzBvDqzgI","label":"mentions"},{"source":"reckTSwmGnaNloYcH","target":"rec1ZMFtfbEvoGC73","label":"mentions"},{"source":"reckTSwmGnaNloYcH","target":"recNlVijtEIdQhAIm","label":"mentions"},{"source":"reckTSwmGnaNloYcH","target":"rec0BAacWSGBXZ0zI","label":"mentions"},{"source":"reckTSwmGnaNloYcH","target":"recjNRR60PAuFtjha","label":"mentions"},{"source":"reckTSwmGnaNloYcH","target":"recNOn1RcB3sCzCnh","label":"mentions"},{"source":"reckTSwmGnaNloYcH","target":"recL1WV82pXaRBQ59","label":"mentions"},{"source":"reckTSwmGnaNloYcH","target":"recBsRcVlu8hkiGKW","label":"mentions"},{"source":"reckTSwmGnaNloYcH","target":"recpqKANUDcRgN4HU","label":"mentions"},{"source":"reckTSwmGnaNloYcH","target":"recIJFRcqI6KbKgXb","label":"mentions"},{"source":"reckTSwmGnaNloYcH","target":"recppjCaJndWnPp96","label":"mentions"},{"source":"reckTSwmGnaNloYcH","target":"recIF1Q0gHP65ziSy","label":"mentions"},{"source":"reckTSwmGnaNloYcH","target":"recOW0FKyYhhTt7vV","label":"mentions"}],"verses":[{"id":"rec1mKoyd5StpWLYB","ref":"2Chr.33.1","text":"Manasseh was twelve years old when he began to reign, and he reigned fifty and five years in Jerusalem:","year":-693},{"id":"recAu14Awq3JxUoqM","ref":"2Chr.33.2","text":"But did that which was evil in the sight of the LORD, like unto the abominations of the heathen, whom the LORD had cast out before the children of Israel.","year":-693},{"id":"recB2c5m3XYINX0by","ref":"2Chr.33.3","text":"For he built again the high places which Hezekiah his father had broken down, and he reared up altars for Baalim, and made groves, and worshipped all the host of heaven, and served them.","year":-693},{"id":"recH074HoX0y1zkDy","ref":"2Chr.33.4","text":"Also he built altars in the house of the LORD, whereof the LORD had said, In Jerusalem shall my name be for ever.","year":-693},{"id":"recnQ1UA3nSAZoeF0","ref":"2Chr.33.5","text":"And he built altars for all the host of heaven in the two courts of the house of the LORD.","year":-693},{"id":"recw6aMeuQZV3u2Ec","ref":"2Chr.33.6","text":"And he caused his children to pass through the fire in the valley of the son of Hinnom: also he observed times, and used enchantments, and used witchcraft, and dealt with a familiar spirit, and with wizards: he wrought much evil in the sight of the LORD, to provoke him to anger.","year":-693},{"id":"rec2TnYbOxhBHiLfe","ref":"2Chr.33.7","text":"And he set a carved image, the idol which he had made, in the house of God, of which God had said to David and to Solomon his son, In this house, and in Jerusalem, which I have chosen before all the tribes of Israel, will I put my name for ever:","year":-693},{"id":"reczgt1IRedxDDGo0","ref":"2Chr.33.8","text":"Neither will I any more remove the foot of Israel from out of the land which I have appointed for your fathers; so that they will take heed to do all that I have commanded them, according to the whole law and the statutes and the ordinances by the hand of Moses.","year":-693}]}
