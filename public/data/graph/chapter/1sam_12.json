core":1},{"id":"recUn6eVJDoG4xI0j","type":"place","group":"mentioned","label":"Moab","slug":"moab_815","score":1},{"id":"recKRsEFLaEueJvei","type":"event","group":"event","label":"Reign of Saul","slug":"event-155","score":25}],"links":[{"source":"recqxpqRX1OtlmF04","target":"rec4GS8yWh2R4mpdB","label":"part of"},{"source":"recqxpqRX1OtlmF04","target":"reccZB8SVU5bEMcgo","label":"mentions"},{"source":"recqxpqRX1OtlmF04","target":"recZsS2Zu0zIDwqdv","label":"mentions"},{"source":"recqxpqRX1OtlmF04","target":"recjNRR60PAuFtjha","label":"mentions"},{"source":"recqxpqRX1OtlmF04","target":"recv0dAY2ULzJ687g","label":"mentions"},{"source":"recqxpqRX1OtlmF04","target":"recsU2ZSdzBvDqzgI","label":"mentions"},{"source":"recqxpqRX1OtlmF04","target":"recCQlDLuGURuOOBb","label":"mentions"},{"source":"recqxpqRX1OtlmF04","target":"rec3qiPi8JN2h86Mj","label":"mentions"},{"source":"recqxpqRX1OtlmF04","target":"recjU9TzJTjllYnUJ","label":"mentions"},{"source":"recqxpqRX1OtlmF04","target":"reck9tbT0TayJOE8k","label":"mentions"},{"source":"recqxpqRX1OtlmF04","target":"recIo7V1LEn9xfvcc","label":"mentions"},{"source":"recqxpqRX1OtlmF04","target":"rec9qYH7v18mn09Mt","label":"mentions"},{"source":"recqxpqRX1OtlmF04","target":"recfrXyxhuYOczKTm","label":"mentions"},{"source":"recqxpqRX1OtlmF04","target":"recCFbPoMSDmIyxXM","label":"mentions"},{"source":"recqxpqRX1OtlmF04","target":"recUn6eVJDoG4xI0j","label":"mentions"},{"source":"recqxpqRX1OtlmF04","target":"recKRsEFLaEueJvei","label":"event"}],"verses":[{"id":"recg8UyXLMPK20h9V","ref":"1Sam.12.1","text":"And Samuel said unto all Israel, Behold, I have hearkened unto your voice in all that ye said unto me, and have made a king over you.","year":-1095},{"id":"recPq18eAY5JsjLiP","ref":"1Sam.12.2","text":"And now, behold, the king walketh before you: and I am old and grayheaded; and, behold, my sons are with you: and I have walked before you from my childhood unto this day.","year":-1095},{"id":"recP9JRfdaBMMyln9","ref":"1Sam.12.3","text":"Behold, here I am: witness against me before the LORD, and before his anointed: whose ox have I taken? or whose ass have I taken? or whom have I defrauded? whom have I oppressed? or of whose hand have I received any bribe to blind mine eyes therewith? and I will restore it you.","year":-1095},{"id":"reci9b1jNgIt6Xxo0","ref":"1Sam.12.4","text":"And they said, Thou hast not defrauded us, nor oppressed us, neither hast thou taken ought of any man’s hand.","year":-1095},{"id":"recjZ4XrUICyxLre0","ref":"1Sam.12.5","text":"And he said unto them, The LORD is witness against you, and his anointed is witness this day, that ye have not found ought in my hand. And they answered, He is witness.","year":-1095},{"id":"recMOfqiXqpit0T9W","ref":"1Sam.12.6","text":"And Samuel said unto the people, It is the LORD that advanced Moses and Aaron, and that brought your fathers up out of the land of Egypt.","year":-1095},{"id":"recOatIZ8Ow97l9Mq","ref":"1Sam.12.7","text":"Now therefore stand still, that I may reason with you before the LORD of all the righteous acts of the LORD, which he did to you and to your fathers.","year":-1095},{"id":"recbgFzRzLDEGFsD9","ref":"1Sam.12.8","text":"When Jacob was come into Egypt, and your fathers cried unto the LORD, then the LORD sent Moses and Aaron, which brought forth your fathers out of Egypt, and made them dwell in this place.","year":-1095}]}
