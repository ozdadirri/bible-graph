{"entity":{"id":"recC7eHfosTXlVT5U","type":"chapter","slug":"recC7eHfosTXlVT5U","label":"3John.1","rawId":"recC7eHfosTXlVT5U","book":{"id":"recMApftYXBHE8lV5","type":"book","slug":"3john","label":"3 John","subtitle":"General Epistles","count":14,"description":"1 chapters, 4 people, 0 places"}},"stats":{"verses":14,"people":4,"places":0,"events":0},"nodes":[{"id":"recC7eHfosTXlVT5U","type":"chapter","group":"focus","label":"3John.1","slug":"3john_1","score":14},{"id":"recMApftYXBHE8lV5","type":"book","group":"book","label":"3 John","slug":"3john","score":14},{"id":"recI3j3vovxhEjhnP","type":"person","group":"mentioned","label":"Gaius","slug":"gaius_1272","score":1},{"id":"recRd8VDsVN2BRjwo","type":"person","group":"mentioned","label":"Diotrephes","slug":"diotrephes_1014","score":1},{"id":"reccZB8SVU5bEMcgo","type":"person","group":"mentioned","label":"God","slug":"god_1324","score":1},{"id":"recnjSr5ffVmmz3Rf","type":"person","group":"mentioned","label":"Demetrius","slug":"demetrius_1007","score":1}],"links":[{"source":"recC7eHfosTXlVT5U","target":"recMApftYXBHE8lV5","label":"part of"},{"source":"recC7eHfosTXlVT5U","target":"recI3j3vovxhEjhnP","label":"mentions"},{"source":"recC7eHfosTXlVT5U","target":"recRd8VDsVN2BRjwo","label":"mentions"},{"source":"recC7eHfosTXlVT5U","target":"reccZB8SVU5bEMcgo","label":"mentions"},{"source":"recC7eHfosTXlVT5U","target":"recnjSr5ffVmmz3Rf","label":"mentions"}],"verses":[{"id":"recQEgzU2qUisV8cc","ref":"3John.1.1","text":"The elder unto the wellbeloved Gaius, whom I love in the truth.","year":90},{"id":"recjJZ3fXYtHKaKjg","ref":"3John.1.2","text":"Beloved, I wish above all things that thou mayest prosper and be in health, even as thy soul prospereth.","year":90},{"id":"rec5USXY8XKMq52R5","ref":"3John.1.3","text":"For I rejoiced greatly, when the brethren came and testified of the truth that is in thee, even as thou walkest in the truth.","year":90},{"id":"recIdy65ISAauFacX","ref":"3John.1.4","text":"I have no greater joy than to hear that my children walk in truth.","year":90},{"id":"recaNbhkRsS8PQ00L","ref":"3John.1.5","text":"Beloved, thou doest faithfully whatsoever thou doest to the brethren, and to strangers;","year":90},{"id":"rec8u93J5FgbCSdNH","ref":"3John.1.6","text":"Which have borne witness of thy charity before the church: whom if thou bring forward on their journey after a godly sort, thou shalt do well:","year":90},{"id":"reczv7IxteD5D6wYk","ref":"3John.1.7","text":"Because that for his name’s sake they went forth, taking nothing of the Gentiles.","year":90},{"id":"recVe1vBxTnUJ4lE8","ref":"3John.1.8","text":"We therefore ought to receive such, that we might be fellowhelpers to the truth.","year":90}]}
