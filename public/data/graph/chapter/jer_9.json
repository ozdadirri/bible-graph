FqPvnuYfMu","target":"recL1WV82pXaRBQ59","label":"mentions"},{"source":"recaUxqFqPvnuYfMu","target":"reczPjeq0UdahiRrn","label":"mentions"},{"source":"recaUxqFqPvnuYfMu","target":"recUn6eVJDoG4xI0j","label":"mentions"},{"source":"recaUxqFqPvnuYfMu","target":"recfrXyxhuYOczKTm","label":"mentions"},{"source":"recaUxqFqPvnuYfMu","target":"recLcxRZbz3yIQB7b","label":"mentions"},{"source":"recaUxqFqPvnuYfMu","target":"recRqzbUZ7i6OPTa1","label":"mentions"},{"source":"recaUxqFqPvnuYfMu","target":"rec5pDuWtEaOK7ehk","label":"event"}],"verses":[{"id":"recZGinabtIxsHUIk","ref":"Jer.9.1","text":"Oh that my head were waters, and mine eyes a fountain of tears, that I might weep day and night for the slain of the daughter of my people!","year":-610},{"id":"recEUot5ZKf6DctG5","ref":"Jer.9.2","text":"Oh that I had in the wilderness a lodging place of wayfaring men; that I might leave my people, and go from them! for they be all adulterers, an assembly of treacherous men.","year":-610},{"id":"recD0AOP2AQACo3Ml","ref":"Jer.9.3","text":"And they bend their tongues like their bow for lies: but they are not valiant for the truth upon the earth; for they proceed from evil to evil, and they know not me, saith the LORD.","year":-610},{"id":"rec7JlEruEHe3VnVw","ref":"Jer.9.4","text":"Take ye heed every one of his neighbour, and trust ye not in any brother: for every brother will utterly supplant, and every neighbour will walk with slanders.","year":-610},{"id":"recDE1kfuxPJ1bVtD","ref":"Jer.9.5","text":"And they will deceive every one his neighbour, and will not speak the truth: they have taught their tongue to speak lies, and weary themselves to commit iniquity.","year":-610},{"id":"rechLigPFoecRng8W","ref":"Jer.9.6","text":"Thine habitation is in the midst of deceit; through deceit they refuse to know me, saith the LORD.","year":-610},{"id":"recU26lrYNWS5FpYV","ref":"Jer.9.7","text":"Therefore thus saith the LORD of hosts, Behold, I will melt them, and try them; for how shall I do for the daughter of my people?","year":-610},{"id":"recPQnqK2xbQEIP1g","ref":"Jer.9.8","text":"Their tongue is as an arrow shot out; it speaketh deceit: one speaketh peaceably to his neighbour with his mouth, but in heart he layeth his wait.","year":-610}]}
