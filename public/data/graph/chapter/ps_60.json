:"recUL0iWPzeEhRESl","target":"recUySlrBva4ffoVs","label":"mentions"},{"source":"recUL0iWPzeEhRESl","target":"recGrj7fktYfxmcbO","label":"mentions"},{"source":"recUL0iWPzeEhRESl","target":"recPoImnA7S93jcHx","label":"mentions"},{"source":"recUL0iWPzeEhRESl","target":"recirR7tLEeni78L3","label":"mentions"},{"source":"recUL0iWPzeEhRESl","target":"recUn6eVJDoG4xI0j","label":"mentions"}],"verses":[{"id":"rec2HyFTVq62V1NR5","ref":"Ps.60.1","text":"O God, thou hast cast us off, thou hast scattered us, thou hast been displeased; O turn thyself to us again."},{"id":"recxzZW0mkagzyjM6","ref":"Ps.60.2","text":"Thou hast made the earth to tremble; thou hast broken it: heal the breaches thereof; for it shaketh."},{"id":"recixiNxZD4cmEj2g","ref":"Ps.60.3","text":"Thou hast shewed thy people hard things: thou hast made us to drink the wine of astonishment."},{"id":"recztGTNYQfvMPjoo","ref":"Ps.60.4","text":"Thou hast given a banner to them that fear thee, that it may be displayed because of the truth. Selah."},{"id":"recvL6s5ocQ6p8CZF","ref":"Ps.60.5","text":"That thy beloved may be delivered; save with thy right hand, and hear me."},{"id":"recaAgMfzFTXTNisT","ref":"Ps.60.6","text":"God hath spoken in his holiness; I will rejoice, I will divide Shechem, and mete out the valley of Succoth."},{"id":"recrPaO5Dwe06stcq","ref":"Ps.60.7","text":"Gilead is mine, and Manasseh is mine; Ephraim also is the strength of mine head; Judah is my lawgiver;"},{"id":"rec6cnXirK5xKkqXx","ref":"Ps.60.8","text":"Moab is my washpot; over Edom will I cast out my shoe: Philistia, triumph thou because of me."}]}
