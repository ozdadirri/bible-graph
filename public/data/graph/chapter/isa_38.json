ions"},{"source":"recVQWYL1yipU8MPZ","target":"recIJFRcqI6KbKgXb","label":"mentions"},{"source":"recVQWYL1yipU8MPZ","target":"recQ1bj3p4Lj5MYY6","label":"event"}],"verses":[{"id":"rec0psHqXA79kGTlM","ref":"Isa.38.1","text":"In those days was Hezekiah sick unto death. And Isaiah the prophet the son of Amoz came unto him, and said unto him, Thus saith the LORD, Set thine house in order: for thou shalt die, and not live.","year":-718},{"id":"recQMuLE7BF6iuRuE","ref":"Isa.38.2","text":"Then Hezekiah turned his face toward the wall, and prayed unto the LORD,","year":-718},{"id":"recqwbP6WViwS0cWK","ref":"Isa.38.3","text":"And said, Remember now, O LORD, I beseech thee, how I have walked before thee in truth and with a perfect heart, and have done that which is good in thy sight. And Hezekiah wept sore.","year":-718},{"id":"recyDTM7POCWYU932","ref":"Isa.38.4","text":"Then came the word of the LORD to Isaiah, saying,","year":-718},{"id":"recXdB1yYMBWiRuy3","ref":"Isa.38.5","text":"Go, and say to Hezekiah, Thus saith the LORD, the God of David thy father, I have heard thy prayer, I have seen thy tears: behold, I will add unto thy days fifteen years.","year":-718},{"id":"rec6Tt3yETwcKO5rf","ref":"Isa.38.6","text":"And I will deliver thee and this city out of the hand of the king of Assyria: and I will defend this city.","year":-718},{"id":"rec1Aj4L1G7ZL3HCR","ref":"Isa.38.7","text":"And this shall be a sign unto thee from the LORD, that the LORD will do this thing that he hath spoken;","year":-718},{"id":"recpIZpSAC5AbRZof","ref":"Isa.38.8","text":"Behold, I will bring again the shadow of the degrees, which is gone down in the sun dial of Ahaz, ten degrees backward. So the sun returned ten degrees, by which degrees it was gone down.","year":-718}]}
