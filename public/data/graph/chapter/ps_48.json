{"entity":{"id":"rec3wmzMFsmelBYgG","type":"chapter","slug":"rec3wmzMFsmelBYgG","label":"Ps.48","rawId":"rec3wmzMFsmelBYgG","book":{"id":"recKXZXO6cJwk2SxO","type":"book","slug":"ps","label":"Psalms","subtitle":"Poetry-Wisdom","count":2461,"description":"150 chapters, 1026 people, 118 places"}},"stats":{"verses":14,"people":1,"places":3,"events":0},"nodes":[{"id":"rec3wmzMFsmelBYgG","type":"chapter","group":"focus","label":"Ps.48","slug":"ps_48","score":14},{"id":"recKXZXO6cJwk2SxO","type":"book","group":"book","label":"Psalms","slug":"ps","score":2461},{"id":"reccZB8SVU5bEMcgo","type":"person","group":"mentioned","label":"God","slug":"god_1324","score":6},{"id":"rechZwu8ZbWlB6fyU","type":"place","group":"mentioned","label":"Mount Zion","slug":"mount_zion_860","score":2},{"id":"rec8hi9Ksp4awz9FJ","type":"place","group":"mentioned","label":"Tarshish","slug":"tarshish_1139","score":1},{"id":"reczPjeq0UdahiRrn","type":"place","group":"mentioned","label":"Zion","slug":"zion_1263","score":1}],"links":[{"source":"rec3wmzMFsmelBYgG","target":"recKXZXO6cJwk2SxO","label":"part of"},{"source":"rec3wmzMFsmelBYgG","target":"reccZB8SVU5bEMcgo","label":"mentions"},{"source":"rec3wmzMFsmelBYgG","target":"rechZwu8ZbWlB6fyU","label":"mentions"},{"source":"rec3wmzMFsmelBYgG","target":"rec8hi9Ksp4awz9FJ","label":"mentions"},{"source":"rec3wmzMFsmelBYgG","target":"reczPjeq0UdahiRrn","label":"mentions"}],"verses":[{"id":"receUuffuWCepG3Se","ref":"Ps.48.1","text":"Great is the LORD, and greatly to be praised in the city of our God, in the mountain of his holiness."},{"id":"recEjZLHhG2pKnug0","ref":"Ps.48.2","text":"Beautiful for situation, the joy of the whole earth, is mount Zion, on the sides of the north, the city of the great King."},{"id":"receZTJbPfSwXjDGK","ref":"Ps.48.3","text":"God is known in her palaces for a refuge."},{"id":"reccohnSQJk8jMh9N","ref":"Ps.48.4","text":"For, lo, the kings were assembled, they passed by together."},{"id":"recSXXDY6dXqgQibN","ref":"Ps.48.5","text":"They saw it, and so they marvelled; they were troubled, and hasted away."},{"id":"recuJh5vBNq1qU0bc","ref":"Ps.48.6","text":"Fear took hold upon them there, and pain, as of a woman in travail."},{"id":"recdANdHJvagwM3ei","ref":"Ps.48.7","text":"Thou breakest the ships of Tarshish with an east wind."},{"id":"recONdDuaneI8X5nF","ref":"Ps.48.8","text":"As we have heard, so have we seen in the city of the LORD of hosts, in the city of our God: God will establish it for ever. Selah."}]}
