ns"},{"source":"recPfZC7YcYKoQZis","target":"rec34nlC2Rt0dlYyu","label":"mentions"},{"source":"recPfZC7YcYKoQZis","target":"recQ1bj3p4Lj5MYY6","label":"event"}],"verses":[{"id":"recwRKeAjIVCmjQhJ","ref":"Isa.13.1","text":"The burden of Babylon, which Isaiah the son of Amoz did see.","year":-712},{"id":"recSHdOMpXftsqwBz","ref":"Isa.13.2","text":"Lift ye up a banner upon the high mountain, exalt the voice unto them, shake the hand, that they may go into the gates of the nobles.","year":-712},{"id":"recnIJHnArPbHy1Cb","ref":"Isa.13.3","text":"I have commanded my sanctified ones, I have also called my mighty ones for mine anger, even them that rejoice in my highness.","year":-712},{"id":"recsM9TSliOilXgqs","ref":"Isa.13.4","text":"The noise of a multitude in the mountains, like as of a great people; a tumultuous noise of the kingdoms of nations gathered together: the LORD of hosts mustereth the host of the battle.","year":-712},{"id":"reciagE0bdHf7nt50","ref":"Isa.13.5","text":"They come from a far country, from the end of heaven, even the LORD, and the weapons of his indignation, to destroy the whole land.","year":-712},{"id":"recV9bjwTKL4DQijU","ref":"Isa.13.6","text":"Howl ye; for the day of the LORD is at hand; it shall come as a destruction from the Almighty.","year":-712},{"id":"recLhT6JGOFXIi9HD","ref":"Isa.13.7","text":"Therefore shall all hands be faint, and every man’s heart shall melt:","year":-712},{"id":"reczQzth9cMF6SY1E","ref":"Isa.13.8","text":"And they shall be afraid: pangs and sorrows shall take hold of them; they shall be in pain as a woman that travaileth: they shall be amazed one at another; their faces shall be as flames.","year":-712}]}
