{"entity":{"id":"rec9bGo1MwA1gOgDv","type":"chapter","slug":"rec9bGo1MwA1gOgDv","label":"Job.12","rawId":"rec9bGo1MwA1gOgDv","book":{"id":"recOA8nVVhKs30PSI","type":"book","slug":"job","label":"Job","subtitle":"Poetry-Wisdom","count":1070,"description":"42 chapters, 190 people, 6 places"}},"stats":{"verses":25,"people":2,"places":0,"events":1},"nodes":[{"id":"rec9bGo1MwA1gOgDv","type":"chapter","group":"focus","label":"Job.12","slug":"job_12","score":25},{"id":"recOA8nVVhKs30PSI","type":"book","group":"book","label":"Job","slug":"job","score":1070},{"id":"reccZB8SVU5bEMcgo","type":"person","group":"mentioned","label":"God","slug":"god_1324","score":3},{"id":"recKXL1QrW8qTw5Ux","type":"person","group":"mentioned","label":"Job","slug":"job_1639","score":1},{"id":"recMNT9RB1RJiLlYW","type":"event","group":"event","label":"Job's Trial","slug":"event-117","score":25}],"links":[{"source":"rec9bGo1MwA1gOgDv","target":"recOA8nVVhKs30PSI","label":"part of"},{"source":"rec9bGo1MwA1gOgDv","target":"reccZB8SVU5bEMcgo","label":"mentions"},{"source":"rec9bGo1MwA1gOgDv","target":"recKXL1QrW8qTw5Ux","label":"mentions"},{"source":"rec9bGo1MwA1gOgDv","target":"recMNT9RB1RJiLlYW","label":"event"}],"verses":[{"id":"recbSi5mKBd4762FM","ref":"Job.12.1","text":"And Job answered and said,","year":-1520},{"id":"recGRen9nVP2Xkmwv","ref":"Job.12.2","text":"No doubt but ye are the people, and wisdom shall die with you.","year":-1520},{"id":"recgQou5RC8aPbU2L","ref":"Job.12.3","text":"But I have understanding as well as you; I am not inferior to you: yea, who knoweth not such things as these?","year":-1520},{"id":"recJnWeQI1j0w7RR0","ref":"Job.12.4","text":"I am as one mocked of his neighbour, who calleth upon God, and he answereth him: the just upright man is laughed to scorn.","year":-1520},{"id":"recNRaqR2OBwVtALP","ref":"Job.12.5","text":"He that is ready to slip with his feet is as a lamp despised in the thought of him that is at ease.","year":-1520},{"id":"recOzUBZmSFcFJU2r","ref":"Job.12.6","text":"The tabernacles of robbers prosper, and they that provoke God are secure; into whose hand God bringeth abundantly.","year":-1520},{"id":"recXeVqbx2WspJvj0","ref":"Job.12.7","text":"But ask now the beasts, and they shall teach thee; and the fowls of the air, and they shall tell thee:","year":-1520},{"id":"recAjtskAqLNnEAQu","ref":"Job.12.8","text":"Or speak to the earth, and it shall teach thee: and the fishes of the sea shall declare unto thee.","year":-1520}]}
