JFB3FV5","type":"place","group":"mentioned","label":"Ramoth","slug":"ramoth_983","score":1},{"id":"recPoImnA7S93jcHx","type":"place","group":"mentioned","label":"Gilead","slug":"gilead_475","score":1},{"id":"recwpg56oDIY5SWvr","type":"place","group":"mentioned","label":"Beth-peor","slug":"beth-peor_228","score":1}],"links":[{"source":"reci3ABDBRzY9GpaG","target":"rec2LnZw7EoTWReC0","label":"part of"},{"source":"reci3ABDBRzY9GpaG","target":"reccZB8SVU5bEMcgo","label":"mentions"},{"source":"reci3ABDBRzY9GpaG","target":"recjNRR60PAuFtjha","label":"mentions"},{"source":"reci3ABDBRzY9GpaG","target":"recsU2ZSdzBvDqzgI","label":"mentions"},{"source":"reci3ABDBRzY9GpaG","target":"recE9nWKk1vLR7zi1","label":"mentions"},{"source":"reci3ABDBRzY9GpaG","target":"recyWfFMHv6ZLJkxq","label":"mentions"},{"source":"reci3ABDBRzY9GpaG","target":"rec1jHj7xGKocQO5m","label":"mentions"},{"source":"reci3ABDBRzY9GpaG","target":"rec5dSSsOutWlH2fW","label":"mentions"},{"source":"reci3ABDBRzY9GpaG","target":"recfrXyxhuYOczKTm","label":"mentions"},{"source":"reci3ABDBRzY9GpaG","target":"recufFfLnRDrtxLnL","label":"mentions"},{"source":"reci3ABDBRzY9GpaG","target":"recgdvRbWEPMp5I0z","label":"mentions"},{"source":"reci3ABDBRzY9GpaG","target":"recFPceE2ivY1B3sX","label":"mentions"},{"source":"reci3ABDBRzY9GpaG","target":"recRpIvrxowDc7mVt","label":"mentions"},{"source":"reci3ABDBRzY9GpaG","target":"recwBsc9ohHXV6b60","label":"mentions"},{"source":"reci3ABDBRzY9GpaG","target":"rec9szH9mCJFB3FV5","label":"mentions"},{"source":"reci3ABDBRzY9GpaG","target":"recPoImnA7S93jcHx","label":"mentions"},{"source":"reci3ABDBRzY9GpaG","target":"recwpg56oDIY5SWvr","label":"mentions"}],"verses":[{"id":"rec6Ns51TE0u8jgJ4","ref":"Deut.4.1","text":"Now therefore hearken, O Israel, unto the statutes and unto the judgments, which I teach you, for to do them, that ye may live, and go in and possess the land which the LORD God of your fathers giveth you.","year":-1451},{"id":"recAUE2n8vZWklW2b","ref":"Deut.4.2","text":"Ye shall not add unto the word which I command you, neither shall ye diminish ought from it, that ye may keep the commandments of the LORD your God which I command you.","year":-1451},{"id":"rec5892POJJbN42Ev","ref":"Deut.4.3","text":"Your eyes have seen what the LORD did because of Baalpeor: for all the men that followed Baalpeor, the LORD thy God hath destroyed them from among you.","year":-1451},{"id":"recrFAa07LNpFZkEA","ref":"Deut.4.4","text":"But ye that did cleave unto the LORD your God are alive every one of you this day.","year":-1451},{"id":"recxsPfujj3Un2CDS","ref":"Deut.4.5","text":"Behold, I have taught you statutes and judgments, even as the LORD my God commanded me, that ye should do so in the land whither ye go to possess it.","year":-1451},{"id":"rec4RVfxbon8If9p0","ref":"Deut.4.6","text":"Keep therefore and do them; for this is your wisdom and your understanding in the sight of the nations, which shall hear all these statutes, and say, Surely this great nation is a wise and understanding people.","year":-1451},{"id":"reccKKanMumjxm1VN","ref":"Deut.4.7","text":"For what nation is there so great, who hath God so nigh unto them, as the LORD our God is in all things that we call upon him for?","year":-1451},{"id":"recTnlNQUAB8f4dS0","ref":"Deut.4.8","text":"And what nation is there so great, that hath statutes and judgments so righteous as all this law, which I set before you this day?","year":-1451}]}
