core":1}],"links":[{"source":"recWDY4XojvMEoD6D","target":"recsr5TGvFGOwA5SZ","label":"part of"},{"source":"recWDY4XojvMEoD6D","target":"reccZB8SVU5bEMcgo","label":"mentions"},{"source":"recWDY4XojvMEoD6D","target":"recjNRR60PAuFtjha","label":"mentions"},{"source":"recWDY4XojvMEoD6D","target":"recv0dAY2ULzJ687g","label":"mentions"},{"source":"recWDY4XojvMEoD6D","target":"recsU2ZSdzBvDqzgI","label":"mentions"},{"source":"recWDY4XojvMEoD6D","target":"recOdl9oB4UWmbiqP","label":"mentions"},{"source":"recWDY4XojvMEoD6D","target":"reccdFYIq50NyxNej","label":"mentions"},{"source":"recWDY4XojvMEoD6D","target":"recqIoG1fkaNWJ1y0","label":"mentions"},{"source":"recWDY4XojvMEoD6D","target":"recxxH0xyhQyXuyh2","label":"mentions"},{"source":"recWDY4XojvMEoD6D","target":"recuAalSpGhVahIhx","label":"mentions"},{"source":"recWDY4XojvMEoD6D","target":"recsI3r5rXZZGdGal","label":"mentions"},{"source":"recWDY4XojvMEoD6D","target":"recfrXyxhuYOczKTm","label":"mentions"},{"source":"recWDY4XojvMEoD6D","target":"rec1RMZhQrrzq5oHJ","label":"mentions"},{"source":"recWDY4XojvMEoD6D","target":"recBZhqAvy5xhTNRn","label":"mentions"}],"verses":[{"id":"recPkAmo56NKft0u2","ref":"Exod.4.1","text":"And Moses answered and said, But, behold, they will not believe me, nor hearken unto my voice: for they will say, The LORD hath not appeared unto thee.","year":-1491},{"id":"recDFWA10SEQNGXsK","ref":"Exod.4.2","text":"And the LORD said unto him, What is that in thine hand? And he said, A rod.","year":-1491},{"id":"recglYkNeGJTfH6ES","ref":"Exod.4.3","text":"And he said, Cast it on the ground. And he cast it on the ground, and it became a serpent; and Moses fled from before it.","year":-1491},{"id":"recluXMrgoR6FhtMF","ref":"Exod.4.4","text":"And the LORD said unto Moses, Put forth thine hand, and take it by the tail. And he put forth his hand, and caught it, and it became a rod in his hand:","year":-1491},{"id":"recURqPKrHTWA9fFQ","ref":"Exod.4.5","text":"That they may believe that the LORD God of their fathers, the God of Abraham, the God of Isaac, and the God of Jacob, hath appeared unto thee.","year":-1491},{"id":"recM1paju0HWBlYj8","ref":"Exod.4.6","text":"And the LORD said furthermore unto him, Put now thine hand into thy bosom. And he put his hand into his bosom: and when he took it out, behold, his hand was leprous as snow.","year":-1491},{"id":"recEkXdy1GTMXg03C","ref":"Exod.4.7","text":"And he said, Put thine hand into thy bosom again. And he put his hand into his bosom again; and plucked it out of his bosom, and, behold, it was turned again as his other flesh.","year":-1491},{"id":"recpPAGzrNqgsuLFC","ref":"Exod.4.8","text":"And it shall come to pass, if they will not believe thee, neither hearken to the voice of the first sign, that they will believe the voice of the latter sign.","year":-1491}]}
