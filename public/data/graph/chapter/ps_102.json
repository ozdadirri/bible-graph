{"entity":{"id":"recM055BzJglyMbl5","type":"chapter","slug":"recM055BzJglyMbl5","label":"Ps.102","rawId":"recM055BzJglyMbl5","book":{"id":"recKXZXO6cJwk2SxO","type":"book","slug":"ps","label":"Psalms","subtitle":"Poetry-Wisdom","count":2461,"description":"150 chapters, 1026 people, 118 places"}},"stats":{"verses":28,"people":1,"places":2,"events":0},"nodes":[{"id":"recM055BzJglyMbl5","type":"chapter","group":"focus","label":"Ps.102","slug":"ps_102","score":28},{"id":"recKXZXO6cJwk2SxO","type":"book","group":"book","label":"Psalms","slug":"ps","score":2461},{"id":"reccZB8SVU5bEMcgo","type":"person","group":"mentioned","label":"God","slug":"god_1324","score":9},{"id":"reczPjeq0UdahiRrn","type":"place","group":"mentioned","label":"Zion","slug":"zion_1263","score":3},{"id":"recL1WV82pXaRBQ59","type":"place","group":"mentioned","label":"Jerusalem","slug":"jerusalem_636","score":1}],"links":[{"source":"recM055BzJglyMbl5","target":"recKXZXO6cJwk2SxO","label":"part of"},{"source":"recM055BzJglyMbl5","target":"reccZB8SVU5bEMcgo","label":"mentions"},{"source":"recM055BzJglyMbl5","target":"reczPjeq0UdahiRrn","label":"mentions"},{"source":"recM055BzJglyMbl5","target":"recL1WV82pXaRBQ59","label":"mentions"}],"verses":[{"id":"recTKHF9aOFnmVeDN","ref":"Ps.102.1","text":"Hear my prayer, O LORD, and let my cry come unto thee."},{"id":"recHIE1ixWHQsfDXF","ref":"Ps.102.2","text":"Hide not thy face from me in the day when I am in trouble; incline thine ear unto me: in the day when I call answer me speedily."},{"id":"rec7ffYt1L8ATgOSp","ref":"Ps.102.3","text":"For my days are consumed like smoke, and my bones are burned as an hearth."},{"id":"recfhoG83yhW7lXbT","ref":"Ps.102.4","text":"My heart is smitten, and withered like grass; so that I forget to eat my bread."},{"id":"recLmdVQNVE532emJ","ref":"Ps.102.5","text":"By reason of the voice of my groaning my bones cleave to my skin."},{"id":"recEHayXSNFHCQ3S9","ref":"Ps.102.6","text":"I am like a pelican of the wilderness: I am like an owl of the desert."},{"id":"reccfzhHBPXjwTdVM","ref":"Ps.102.7","text":"I watch, and am as a sparrow alone upon the house top."},{"id":"recepxumvBpEII2Vg","ref":"Ps.102.8","text":"Mine enemies reproach me all the day; and they that are mad against me are sworn against me."}]}
