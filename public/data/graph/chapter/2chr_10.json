rusalem_636","score":1}],"links":[{"source":"recYiSm0A4LgIh4Cl","target":"rec410yOewjNfbeE3","label":"part of"},{"source":"recYiSm0A4LgIh4Cl","target":"recqQthL4TAHb0KeC","label":"mentions"},{"source":"recYiSm0A4LgIh4Cl","target":"recXhPherZAxvXTS4","label":"mentions"},{"source":"recYiSm0A4LgIh4Cl","target":"recPF80I9rSEP1EHd","label":"mentions"},{"source":"recYiSm0A4LgIh4Cl","target":"rec0BAacWSGBXZ0zI","label":"mentions"},{"source":"recYiSm0A4LgIh4Cl","target":"rec1ZMFtfbEvoGC73","label":"mentions"},{"source":"recYiSm0A4LgIh4Cl","target":"recsU2ZSdzBvDqzgI","label":"mentions"},{"source":"recYiSm0A4LgIh4Cl","target":"rec1SNN05dlR3SG96","label":"mentions"},{"source":"recYiSm0A4LgIh4Cl","target":"reccZB8SVU5bEMcgo","label":"mentions"},{"source":"recYiSm0A4LgIh4Cl","target":"rec9lplwEhGgkXdOn","label":"mentions"},{"source":"recYiSm0A4LgIh4Cl","target":"recmQCQy94vebCsiC","label":"mentions"},{"source":"recYiSm0A4LgIh4Cl","target":"recUySlrBva4ffoVs","label":"mentions"},{"source":"recYiSm0A4LgIh4Cl","target":"recfrXyxhuYOczKTm","label":"mentions"},{"source":"recYiSm0A4LgIh4Cl","target":"recL1WV82pXaRBQ59","label":"mentions"}],"verses":[{"id":"recqG4LMl50GTkwrw","ref":"2Chr.10.1","text":"And Rehoboam went to Shechem: for to Shechem were all Israel come to make him king.","year":-975},{"id":"recqWggH7gAXleCMY","ref":"2Chr.10.2","text":"And it came to pass, when Jeroboam the son of Nebat, who was in Egypt, whither he had fled from the presence of Solomon the king, heard it, that Jeroboam returned out of Egypt.","year":-975},{"id":"reck2lSHipbvAf042","ref":"2Chr.10.3","text":"And they sent and called him. So Jeroboam and all Israel came and spake to Rehoboam, saying,","year":-975},{"id":"recVMEgTXRDGjrlFR","ref":"2Chr.10.4","text":"Thy father made our yoke grievous: now therefore ease thou somewhat the grievous servitude of thy father, and his heavy yoke that he put upon us, and we will serve thee.","year":-975},{"id":"recjCcOyuxO7jov3v","ref":"2Chr.10.5","text":"And he said unto them, Come again unto me after three days. And the people departed.","year":-975},{"id":"recFVL3s70NqZEyps","ref":"2Chr.10.6","text":"And king Rehoboam took counsel with the old men that had stood before Solomon his father while he yet lived, saying, What counsel give ye me to return answer to this people?","year":-975},{"id":"recmgaKl0n1tnQE9o","ref":"2Chr.10.7","text":"And they spake unto him, saying, If thou be kind to this people, and please them, and speak good words to them, they will be thy servants for ever.","year":-975},{"id":"recaA55VzS8Ll09Wz","ref":"2Chr.10.8","text":"But he forsook the counsel which the old men gave him, and took counsel with the young men that were brought up with him, that stood before him.","year":-975}]}
