{"entity":{"id":"rech9QIYeh48fD7OC","type":"chapter","slug":"rech9QIYeh48fD7OC","label":"Ps.116","rawId":"rech9QIYeh48fD7OC","book":{"id":"recKXZXO6cJwk2SxO","type":"book","slug":"ps","label":"Psalms","subtitle":"Poetry-Wisdom","count":2461,"description":"150 chapters, 1026 people, 118 places"}},"stats":{"verses":19,"people":1,"places":1,"events":0},"nodes":[{"id":"rech9QIYeh48fD7OC","type":"chapter","group":"focus","label":"Ps.116","slug":"ps_116","score":19},{"id":"recKXZXO6cJwk2SxO","type":"book","group":"book","label":"Psalms","slug":"ps","score":2461},{"id":"reccZB8SVU5bEMcgo","type":"person","group":"mentioned","label":"God","slug":"god_1324","score":14},{"id":"recL1WV82pXaRBQ59","type":"place","group":"mentioned","label":"Jerusalem","slug":"jerusalem_636","score":1}],"links":[{"source":"rech9QIYeh48fD7OC","target":"recKXZXO6cJwk2SxO","label":"part of"},{"source":"rech9QIYeh48fD7OC","target":"reccZB8SVU5bEMcgo","label":"mentions"},{"source":"rech9QIYeh48fD7OC","target":"recL1WV82pXaRBQ59","label":"mentions"}],"verses":[{"id":"rec1omvB8CCaHOYut","ref":"Ps.116.1","text":"I love the LORD, because he hath heard my voice and my supplications.","year":-536},{"id":"recbStVOdpt61VrDc","ref":"Ps.116.2","text":"Because he hath inclined his ear unto me, therefore will I call upon him as long as I live.","year":-536},{"id":"recOSvEd2CEDaC2VW","ref":"Ps.116.3","text":"The sorrows of death compassed me, and the pains of hell gat hold upon me: I found trouble and sorrow.","year":-536},{"id":"recuQj6Vzmwyl5D0M","ref":"Ps.116.4","text":"Then called I upon the name of the LORD; O LORD, I beseech thee, deliver my soul.","year":-536},{"id":"recw8n3CN0YEVkNI3","ref":"Ps.116.5","text":"Gracious is the LORD, and righteous; yea, our God is merciful.","year":-536},{"id":"recREvocWkGWavg6p","ref":"Ps.116.6","text":"The LORD preserveth the simple: I was brought low, and he helped me.","year":-536},{"id":"rec6XG88ld656yRXb","ref":"Ps.116.7","text":"Return unto thy rest, O my soul; for the LORD hath dealt bountifully with thee.","year":-536},{"id":"recCK1n2xkwPKoZ2a","ref":"Ps.116.8","text":"For thou hast delivered my soul from death, mine eyes from tears, and my feet from falling.","year":-536}]}
