ore":1},{"id":"rechguBS4b9kXx3z3","type":"event","group":"event","label":"Lifetime of Joshua","slug":"event-124","score":1}],"links":[{"source":"recxGczDPGWmecQhD","target":"reczL2ckRW1qHvVfe","label":"part of"},{"source":"recxGczDPGWmecQhD","target":"reccZB8SVU5bEMcgo","label":"mentions"},{"source":"recxGczDPGWmecQhD","target":"recLuZtSmAO6erIsc","label":"mentions"},{"source":"recxGczDPGWmecQhD","target":"recsU2ZSdzBvDqzgI","label":"mentions"},{"source":"recxGczDPGWmecQhD","target":"rectAKOMFVWfGYUGW","label":"mentions"},{"source":"recxGczDPGWmecQhD","target":"recEtv9ql7Hh4XAW4","label":"mentions"},{"source":"recxGczDPGWmecQhD","target":"recE9nWKk1vLR7zi1","label":"mentions"},{"source":"recxGczDPGWmecQhD","target":"recW1hr037qxVsNBt","label":"mentions"},{"source":"recxGczDPGWmecQhD","target":"recfrXyxhuYOczKTm","label":"mentions"},{"source":"recxGczDPGWmecQhD","target":"recdm9AlLF01lFAfP","label":"mentions"},{"source":"recxGczDPGWmecQhD","target":"recVJJVSqbm0DBuEb","label":"mentions"},{"source":"recxGczDPGWmecQhD","target":"recYPNmOaWy8gnCa8","label":"mentions"},{"source":"recxGczDPGWmecQhD","target":"recUvk5tT0xGxR71o","label":"event"},{"source":"recxGczDPGWmecQhD","target":"recnPiyyKviVUPHO6","label":"event"},{"source":"recxGczDPGWmecQhD","target":"rechguBS4b9kXx3z3","label":"event"}],"verses":[{"id":"recTcuJpgcN2nFJ5a","ref":"Judg.2.1","text":"And an angel of the LORD came up from Gilgal to Bochim, and said, I made you to go up out of Egypt, and have brought you unto the land which I sware unto your fathers; and I said, I will never break my covenant with you."},{"id":"recy7RpfFaJ2eRsoQ","ref":"Judg.2.2","text":"And ye shall make no league with the inhabitants of this land; ye shall throw down their altars: but ye have not obeyed my voice: why have ye done this?"},{"id":"recy667zgZa6JyF7T","ref":"Judg.2.3","text":"Wherefore I also said, I will not drive them out from before you; but they shall be as thorns in your sides, and their gods shall be a snare unto you."},{"id":"recapm8Kj9NKqPLv1","ref":"Judg.2.4","text":"And it came to pass, when the angel of the LORD spake these words unto all the children of Israel, that the people lifted up their voice, and wept."},{"id":"recE6pB0BPu9b2MTO","ref":"Judg.2.5","text":"And they called the name of that place Bochim: and they sacrificed there unto the LORD."},{"id":"recbHF7WtPvqDMSF7","ref":"Judg.2.6","text":"And when Joshua had let the people go, the children of Israel went every man unto his inheritance to possess the land."},{"id":"recUTP0VdT4osi0Jd","ref":"Judg.2.7","text":"And the people served the LORD all the days of Joshua, and all the days of the elders that outlived Joshua, who had seen all the great works of the LORD, that he did for Israel."},{"id":"recVcTWP9SSgGFWoZ","ref":"Judg.2.8","text":"And Joshua the son of Nun, the servant of the LORD, died, being an hundred and ten years old."}]}
