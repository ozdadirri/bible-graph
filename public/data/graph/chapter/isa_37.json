WC34","target":"recYGIjyPqFKqtiKp","label":"mentions"},{"source":"recnoLlI5hkOXWC34","target":"rec1ZMFtfbEvoGC73","label":"mentions"},{"source":"recnoLlI5hkOXWC34","target":"recABuWPq8eOLUHqI","label":"mentions"},{"source":"recnoLlI5hkOXWC34","target":"recibew2LuKVxgRy3","label":"mentions"},{"source":"recnoLlI5hkOXWC34","target":"recsh9hpgxj5TEej4","label":"mentions"},{"source":"recnoLlI5hkOXWC34","target":"recIJFRcqI6KbKgXb","label":"mentions"},{"source":"recnoLlI5hkOXWC34","target":"recL1WV82pXaRBQ59","label":"mentions"},{"source":"recnoLlI5hkOXWC34","target":"rec5g1fzEKYzCO1Re","label":"mentions"},{"source":"recnoLlI5hkOXWC34","target":"recH30EhVzvnkXBTl","label":"mentions"},{"source":"recnoLlI5hkOXWC34","target":"recaHkhAvEICQr7fB","label":"mentions"},{"source":"recnoLlI5hkOXWC34","target":"reckMtGITvZc8u1bI","label":"mentions"},{"source":"recnoLlI5hkOXWC34","target":"recyuzIRhPm1IFEu0","label":"mentions"},{"source":"recnoLlI5hkOXWC34","target":"recsgEmgYboc9zneO","label":"mentions"},{"source":"recnoLlI5hkOXWC34","target":"recLIUK6VRKNjnGo6","label":"mentions"},{"source":"recnoLlI5hkOXWC34","target":"recuNldBULsq0RoMw","label":"mentions"},{"source":"recnoLlI5hkOXWC34","target":"recQ1bj3p4Lj5MYY6","label":"event"}],"verses":[{"id":"recrG59MifFyqvE0Y","ref":"Isa.37.1","text":"And it came to pass, when king Hezekiah heard it, that he rent his clothes, and covered himself with sackcloth, and went into the house of the LORD.","year":-710},{"id":"recWkPGDWr01bVjwb","ref":"Isa.37.2","text":"And he sent Eliakim, who was over the household, and Shebna the scribe, and the elders of the priests covered with sackcloth, unto Isaiah the prophet the son of Amoz.","year":-710},{"id":"recP9sVNVNcJIPjRR","ref":"Isa.37.3","text":"And they said unto him, Thus saith Hezekiah, This day is a day of trouble, and of rebuke, and of blasphemy: for the children are come to the birth, and there is not strength to bring forth.","year":-710},{"id":"recINxmEkULACSGb6","ref":"Isa.37.4","text":"It may be the LORD thy God will hear the words of Rabshakeh, whom the king of Assyria his master hath sent to reproach the living God, and will reprove the words which the LORD thy God hath heard: wherefore lift up thy prayer for the remnant that is left.","year":-710},{"id":"reciB5tE2BAKmAQOl","ref":"Isa.37.5","text":"So the servants of king Hezekiah came to Isaiah.","year":-710},{"id":"rec2pgRo2SYWX9sGh","ref":"Isa.37.6","text":"And Isaiah said unto them, Thus shall ye say unto your master, Thus saith the LORD, Be not afraid of the words that thou hast heard, wherewith the servants of the king of Assyria have blasphemed me.","year":-710},{"id":"recqrZAQRySShX6TE","ref":"Isa.37.7","text":"Behold, I will send a blast upon him, and he shall hear a rumour, and return to his own land; and I will cause him to fall by the sword in his own land.","year":-710},{"id":"recFiee9d2GYfisex","ref":"Isa.37.8","text":"So Rabshakeh returned, and found the king of Assyria warring against Libnah: for he had heard that he was departed from Lachish.","year":-710}]}
