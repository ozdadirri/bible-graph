{"entity":{"id":"reczxqgpCwV1GvhzO","type":"chapter","slug":"reczxqgpCwV1GvhzO","label":"John.9","rawId":"reczxqgpCwV1GvhzO","book":{"id":"recq8W1kWwtVoUlwB","type":"book","slug":"john","label":"John","subtitle":"Gospels","count":879,"description":"21 chapters, 514 people, 62 places"}},"stats":{"verses":41,"people":3,"places":1,"events":1},"nodes":[{"id":"reczxqgpCwV1GvhzO","type":"chapter","group":"focus","label":"John.9","slug":"john_9","score":41},{"id":"recq8W1kWwtVoUlwB","type":"book","group":"book","label":"John","slug":"john","score":879},{"id":"recgkFqZovgbr3pAi","type":"person","group":"mentioned","label":"Jesus Christ","slug":"jesus_905","score":10},{"id":"reccZB8SVU5bEMcgo","type":"person","group":"mentioned","label":"God","slug":"god_1324","score":7},{"id":"recjNRR60PAuFtjha","type":"person","group":"mentioned","label":"Moses","slug":"moses_2108","score":1},{"id":"recsSXHp8TaXQVDGH","type":"place","group":"mentioned","label":"Siloam","slug":"siloam_1096","score":2},{"id":"recxURN2uAbTe7CGr","type":"event","group":"event","label":"Blind Man Healed","slug":"event-426","score":41}],"links":[{"source":"reczxqgpCwV1GvhzO","target":"recq8W1kWwtVoUlwB","label":"part of"},{"source":"reczxqgpCwV1GvhzO","target":"recgkFqZovgbr3pAi","label":"mentions"},{"source":"reczxqgpCwV1GvhzO","target":"reccZB8SVU5bEMcgo","label":"mentions"},{"source":"reczxqgpCwV1GvhzO","target":"recjNRR60PAuFtjha","label":"mentions"},{"source":"reczxqgpCwV1GvhzO","target":"recsSXHp8TaXQVDGH","label":"mentions"},{"source":"reczxqgpCwV1GvhzO","target":"recxURN2uAbTe7CGr","label":"event"}],"verses":[{"id":"recEydJ1DQeTjX3rU","ref":"John.9.1","text":"And as Jesus passed by, he saw a man which was blind from his birth.","year":33},{"id":"rec3p68hbXODjmO3w","ref":"John.9.2","text":"And his disciples asked him, saying, Master, who did sin, this man, or his parents, that he was born blind?","year":33},{"id":"recdF5MHgjWBszooA","ref":"John.9.3","text":"Jesus answered, Neither hath this man sinned, nor his parents: but that the works of God should be made manifest in him.","year":33},{"id":"recKxFJMFNBoxzzO3","ref":"John.9.4","text":"I must work the works of him that sent me, while it is day: the night cometh, when no man can work.","year":33},{"id":"recLc0gQ4VewAV2uY","ref":"John.9.5","text":"As long as I am in the world, I am the light of the world.","year":33},{"id":"recTWWTltV5zjLhgO","ref":"John.9.6","text":"When he had thus spoken, he spat on the ground, and made clay of the spittle, and he anointed the eyes of the blind man with the clay,","year":33},{"id":"rec5oLzp3Z1VHQVR1","ref":"John.9.7","text":"And said unto him, Go, wash in the pool of Siloam, (which is by interpretation, Sent.) He went his way therefore, and washed, and came seeing.","year":33},{"id":"recua6EEB2HSuzz02","ref":"John.9.8","text":"The neighbours therefore, and they which before had seen him that he was blind, said, Is not this he that sat and begged?","year":33}]}
