{"entity":{"id":"recVAjLhpLJp3XCVR","type":"chapter","slug":"recVAjLhpLJp3XCVR","label":"Job.36","rawId":"recVAjLhpLJp3XCVR","book":{"id":"recOA8nVVhKs30PSI","type":"book","slug":"job","label":"Job","subtitle":"Poetry-Wisdom","count":1070,"description":"42 chapters, 190 people, 6 places"}},"stats":{"verses":33,"people":2,"places":0,"events":1},"nodes":[{"id":"recVAjLhpLJp3XCVR","type":"chapter","group":"focus","label":"Job.36","slug":"job_36","score":33},{"id":"recOA8nVVhKs30PSI","type":"book","group":"book","label":"Job","slug":"job","score":1070},{"id":"reccZB8SVU5bEMcgo","type":"person","group":"mentioned","label":"God","slug":"god_1324","score":4},{"id":"rec6l8j9BdrS5fiDM","type":"person","group":"mentioned","label":"Elihu","slug":"elihu_1130","score":1},{"id":"recMNT9RB1RJiLlYW","type":"event","group":"event","label":"Job's Trial","slug":"event-117","score":33}],"links":[{"source":"recVAjLhpLJp3XCVR","target":"recOA8nVVhKs30PSI","label":"part of"},{"source":"recVAjLhpLJp3XCVR","target":"reccZB8SVU5bEMcgo","label":"mentions"},{"source":"recVAjLhpLJp3XCVR","target":"rec6l8j9BdrS5fiDM","label":"mentions"},{"source":"recVAjLhpLJp3XCVR","target":"recMNT9RB1RJiLlYW","label":"event"}],"verses":[{"id":"recrRWaV4PcbIyjez","ref":"Job.36.1","text":"Elihu also proceeded, and said,","year":-1520},{"id":"recAMllxVfnz4WYPx","ref":"Job.36.2","text":"Suffer me a little, and I will shew thee that I have yet to speak on God’s behalf.","year":-1520},{"id":"reci2E12Pe9EwBxu2","ref":"Job.36.3","text":"I will fetch my knowledge from afar, and will ascribe righteousness to my Maker.","year":-1520},{"id":"recr4Kpk47sMG17Qu","ref":"Job.36.4","text":"For truly my words shall not be false: he that is perfect in knowledge is with thee.","year":-1520},{"id":"recbj7TZXSmEKuTCA","ref":"Job.36.5","text":"Behold, God is mighty, and despiseth not any: he is mighty in strength and wisdom.","year":-1520},{"id":"recmx7bjcczAyqAIg","ref":"Job.36.6","text":"He preserveth not the life of the wicked: but giveth right to the poor.","year":-1520},{"id":"rec2w1wrK8r2l1PFF","ref":"Job.36.7","text":"He withdraweth not his eyes from the righteous: but with kings are they on the throne; yea, he doth establish them for ever, and they are exalted.","year":-1520},{"id":"reczmz9rXKOL9f5Ge","ref":"Job.36.8","text":"And if they be bound in fetters, and be holden in cords of affliction;","year":-1520}]}
