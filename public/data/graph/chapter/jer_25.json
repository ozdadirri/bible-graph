WxqDB09","target":"recNzNKGhPz5qS3Kc","label":"mentions"},{"source":"reckuOWlsnWxqDB09","target":"rec3gWYVMktOUkAzZ","label":"mentions"},{"source":"reckuOWlsnWxqDB09","target":"recMLkyqKWtDeTzWm","label":"mentions"},{"source":"reckuOWlsnWxqDB09","target":"recRqzbUZ7i6OPTa1","label":"mentions"},{"source":"reckuOWlsnWxqDB09","target":"recLcxRZbz3yIQB7b","label":"mentions"},{"source":"reckuOWlsnWxqDB09","target":"rec5pDuWtEaOK7ehk","label":"event"}],"verses":[{"id":"recTBs9iqhtgdDltB","ref":"Jer.25.1","text":"The word that came to Jeremiah concerning all the people of Judah in the fourth year of Jehoiakim the son of Josiah king of Judah, that was the first year of Nebuchadrezzar king of Babylon;","year":-606},{"id":"recAxCguoWy28MyVi","ref":"Jer.25.2","text":"The which Jeremiah the prophet spake unto all the people of Judah, and to all the inhabitants of Jerusalem, saying,","year":-606},{"id":"recSS8OhihBktBbsM","ref":"Jer.25.3","text":"From the thirteenth year of Josiah the son of Amon king of Judah, even unto this day, that is the three and twentieth year, the word of the LORD hath come unto me, and I have spoken unto you, rising early and speaking; but ye have not hearkened.","year":-606},{"id":"recyrC6oZ0yVRhG4j","ref":"Jer.25.4","text":"And the LORD hath sent unto you all his servants the prophets, rising early and sending them; but ye have not hearkened, nor inclined your ear to hear.","year":-606},{"id":"rec6y3VqVi2m0Tecb","ref":"Jer.25.5","text":"They said, Turn ye again now every one from his evil way, and from the evil of your doings, and dwell in the land that the LORD hath given unto you and to your fathers for ever and ever:","year":-606},{"id":"recAqFR8B726ezJw3","ref":"Jer.25.6","text":"And go not after other gods to serve them, and to worship them, and provoke me not to anger with the works of your hands; and I will do you no hurt.","year":-606},{"id":"recOH2v6bNAvdMnzL","ref":"Jer.25.7","text":"Yet ye have not hearkened unto me, saith the LORD; that ye might provoke me to anger with the works of your hands to your own hurt.","year":-606},{"id":"recCZfesdR8lOq3DK","ref":"Jer.25.8","text":"Therefore thus saith the LORD of hosts; Because ye have not heard my words,","year":-606}]}
