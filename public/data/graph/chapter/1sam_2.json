rce":"recs6afL1V306fZC7","target":"reccZB8SVU5bEMcgo","label":"mentions"},{"source":"recs6afL1V306fZC7","target":"recH9ECLXz8IgSUgF","label":"mentions"},{"source":"recs6afL1V306fZC7","target":"recZsS2Zu0zIDwqdv","label":"mentions"},{"source":"recs6afL1V306fZC7","target":"recjwefZcKPa9FN7N","label":"mentions"},{"source":"recs6afL1V306fZC7","target":"reckE2v5xnafaAHdo","label":"mentions"},{"source":"recs6afL1V306fZC7","target":"recOdl9oB4UWmbiqP","label":"mentions"},{"source":"recs6afL1V306fZC7","target":"recsU2ZSdzBvDqzgI","label":"mentions"},{"source":"recs6afL1V306fZC7","target":"recK83c4DLkr3yBX5","label":"mentions"},{"source":"recs6afL1V306fZC7","target":"recrRAVkDKZCXTSl7","label":"mentions"},{"source":"recs6afL1V306fZC7","target":"reczeMGDnN4eb0Y28","label":"mentions"},{"source":"recs6afL1V306fZC7","target":"recPt1Ig1xZkj2YWS","label":"mentions"},{"source":"recs6afL1V306fZC7","target":"recfrXyxhuYOczKTm","label":"mentions"}],"verses":[{"id":"recfL9uDCq0yhP54e","ref":"1Sam.2.1","text":"And Hannah prayed, and said, My heart rejoiceth in the LORD, mine horn is exalted in the LORD: my mouth is enlarged over mine enemies; because I rejoice in thy salvation.","year":-1165},{"id":"reczpdt0B4aqQQItc","ref":"1Sam.2.2","text":"There is none holy as the LORD: for there is none beside thee: neither is there any rock like our God.","year":-1165},{"id":"recq4aqvcwbpf912v","ref":"1Sam.2.3","text":"Talk no more so exceeding proudly; let not arrogancy come out of your mouth: for the LORD is a God of knowledge, and by him actions are weighed.","year":-1165},{"id":"recry7HoN1YysE5Uz","ref":"1Sam.2.4","text":"The bows of the mighty men are broken, and they that stumbled are girded with strength.","year":-1165},{"id":"recXOtJP6UEQTDn23","ref":"1Sam.2.5","text":"They that were full have hired out themselves for bread; and they that were hungry ceased: so that the barren hath born seven; and she that hath many children is waxed feeble.","year":-1165},{"id":"recXrLrkn4PG6TvUO","ref":"1Sam.2.6","text":"The LORD killeth, and maketh alive: he bringeth down to the grave, and bringeth up.","year":-1165},{"id":"recQE8SBxwgpkIeRl","ref":"1Sam.2.7","text":"The LORD maketh poor, and maketh rich: he bringeth low, and lifteth up.","year":-1165},{"id":"recZijDApzjsXegBn","ref":"1Sam.2.8","text":"He raiseth up the poor out of the dust, and lifteth up the beggar from the dunghill, to set them among princes, and to make them inherit the throne of glory: for the pillars of the earth are the LORD’S, and he hath set the world upon them.","year":-1165}]}
