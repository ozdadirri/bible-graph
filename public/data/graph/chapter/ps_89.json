{"entity":{"id":"reclVA1cbLK4WauLF","type":"chapter","slug":"reclVA1cbLK4WauLF","label":"Ps.89","rawId":"reclVA1cbLK4WauLF","book":{"id":"recKXZXO6cJwk2SxO","type":"book","slug":"ps","label":"Psalms","subtitle":"Poetry-Wisdom","count":2461,"description":"150 chapters, 1026 people, 118 places"}},"stats":{"verses":52,"people":2,"places":3,"events":0},"nodes":[{"id":"reclVA1cbLK4WauLF","type":"chapter","group":"focus","label":"Ps.89","slug":"ps_89","score":52},{"id":"recKXZXO6cJwk2SxO","type":"book","group":"book","label":"Psalms","slug":"ps","score":2461},{"id":"reccZB8SVU5bEMcgo","type":"person","group":"mentioned","label":"God","slug":"god_1324","score":13},{"id":"rec1ZMFtfbEvoGC73","type":"person","group":"mentioned","label":"David","slug":"david_994","score":4},{"id":"recFinINtrGjUmVDi","type":"place","group":"mentioned","label":"Rahab","slug":"rahab_969","score":1},{"id":"recmyzVBdbLEBB0Y0","type":"place","group":"mentioned","label":"Tabor (Mountain)","slug":"tabor_1128","score":1},{"id":"recrpaouE7oxrv5jy","type":"place","group":"mentioned","label":"Hermon","slug":"hermon_564","score":1}],"links":[{"source":"reclVA1cbLK4WauLF","target":"recKXZXO6cJwk2SxO","label":"part of"},{"source":"reclVA1cbLK4WauLF","target":"reccZB8SVU5bEMcgo","label":"mentions"},{"source":"reclVA1cbLK4WauLF","target":"rec1ZMFtfbEvoGC73","label":"mentions"},{"source":"reclVA1cbLK4WauLF","target":"recFinINtrGjUmVDi","label":"mentions"},{"source":"reclVA1cbLK4WauLF","target":"recmyzVBdbLEBB0Y0","label":"mentions"},{"source":"reclVA1cbLK4WauLF","target":"recrpaouE7oxrv5jy","label":"mentions"}],"verses":[{"id":"reccrga9zFq4j7Ool","ref":"Ps.89.1","text":"I will sing of the mercies of the LORD for ever: with my mouth will I make known thy faithfulness to all generations."},{"id":"recTkVDClg9ocWRS8","ref":"Ps.89.2","text":"For I have said, Mercy shall be built up for ever: thy faithfulness shalt thou establish in the very heavens."},{"id":"recdMWIjCxYaXoB84","ref":"Ps.89.3","text":"I have made a covenant with my chosen, I have sworn unto David my servant,"},{"id":"recF3aOHHqs4kC8kX","ref":"Ps.89.4","text":"Thy seed will I establish for ever, and build up thy throne to all generations. Selah."},{"id":"recyHHXHNILcCkFiT","ref":"Ps.89.5","text":"And the heavens shall praise thy wonders, O LORD: thy faithfulness also in the congregation of the saints."},{"id":"rec4dfkl0iyYwB2S1","ref":"Ps.89.6","text":"For who in the heaven can be compared unto the LORD? who among the sons of the mighty can be likened unto the LORD?"},{"id":"recwYkccv3L87LAHt","ref":"Ps.89.7","text":"God is greatly to be feared in the assembly of the saints, and to be had in reverence of all them that are about him."},{"id":"recyfUl5S8a0jR4Vy","ref":"Ps.89.8","text":"O LORD God of hosts, who is a strong LORD like unto thee? or to thy faithfulness round about thee?"}]}
