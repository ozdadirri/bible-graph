{"entity":{"id":"recUeChhQe9JCQrMH","type":"chapter","slug":"recUeChhQe9JCQrMH","label":"Ps.94","rawId":"recUeChhQe9JCQrMH","book":{"id":"recKXZXO6cJwk2SxO","type":"book","slug":"ps","label":"Psalms","subtitle":"Poetry-Wisdom","count":2461,"description":"150 chapters, 1026 people, 118 places"}},"stats":{"verses":23,"people":2,"places":0,"events":0},"nodes":[{"id":"recUeChhQe9JCQrMH","type":"chapter","group":"focus","label":"Ps.94","slug":"ps_94","score":23},{"id":"recKXZXO6cJwk2SxO","type":"book","group":"book","label":"Psalms","slug":"ps","score":2461},{"id":"reccZB8SVU5bEMcgo","type":"person","group":"mentioned","label":"God","slug":"god_1324","score":11},{"id":"recsU2ZSdzBvDqzgI","type":"person","group":"mentioned","label":"Jacob (Israel)","slug":"israel_682","score":1}],"links":[{"source":"recUeChhQe9JCQrMH","target":"recKXZXO6cJwk2SxO","label":"part of"},{"source":"recUeChhQe9JCQrMH","target":"reccZB8SVU5bEMcgo","label":"mentions"},{"source":"recUeChhQe9JCQrMH","target":"recsU2ZSdzBvDqzgI","label":"mentions"}],"verses":[{"id":"reccJUZq61mJhpoxr","ref":"Ps.94.1","text":"O LORD God, to whom vengeance belongeth; O God, to whom vengeance belongeth, shew thyself.","year":-588},{"id":"recnqFlRqCmqhZZn4","ref":"Ps.94.2","text":"Lift up thyself, thou judge of the earth: render a reward to the proud.","year":-588},{"id":"rec4SGABfTRVmwwf3","ref":"Ps.94.3","text":"LORD, how long shall the wicked, how long shall the wicked triumph?","year":-588},{"id":"recJCJTsQwbK4xvv9","ref":"Ps.94.4","text":"How long shall they utter and speak hard things? and all the workers of iniquity boast themselves?","year":-588},{"id":"recbY0ayjusP0Cenc","ref":"Ps.94.5","text":"They break in pieces thy people, O LORD, and afflict thine heritage.","year":-588},{"id":"rec5NvaLnyRscgxOf","ref":"Ps.94.6","text":"They slay the widow and the stranger, and murder the fatherless.","year":-588},{"id":"rec1EFYp3Fd0sjO35","ref":"Ps.94.7","text":"Yet they say, The LORD shall not see, neither shall the God of Jacob regard it.","year":-588},{"id":"recsgmy5lp6ncY9Nx","ref":"Ps.94.8","text":"Understand, ye brutish among the people: and ye fools, when will ye be wise?","year":-588}]}
