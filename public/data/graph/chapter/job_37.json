{"entity":{"id":"recWjGiEd3zqrWNRB","type":"chapter","slug":"recWjGiEd3zqrWNRB","label":"Job.37","rawId":"recWjGiEd3zqrWNRB","book":{"id":"recOA8nVVhKs30PSI","type":"book","slug":"job","label":"Job","subtitle":"Poetry-Wisdom","count":1070,"description":"42 chapters, 190 people, 6 places"}},"stats":{"verses":24,"people":2,"places":0,"events":1},"nodes":[{"id":"recWjGiEd3zqrWNRB","type":"chapter","group":"focus","label":"Job.37","slug":"job_37","score":24},{"id":"recOA8nVVhKs30PSI","type":"book","group":"book","label":"Job","slug":"job","score":1070},{"id":"reccZB8SVU5bEMcgo","type":"person","group":"mentioned","label":"God","slug":"god_1324","score":6},{"id":"recKXL1QrW8qTw5Ux","type":"person","group":"mentioned","label":"Job","slug":"job_1639","score":1},{"id":"recMNT9RB1RJiLlYW","type":"event","group":"event","label":"Job's Trial","slug":"event-117","score":24}],"links":[{"source":"recWjGiEd3zqrWNRB","target":"recOA8nVVhKs30PSI","label":"part of"},{"source":"recWjGiEd3zqrWNRB","target":"reccZB8SVU5bEMcgo","label":"mentions"},{"source":"recWjGiEd3zqrWNRB","target":"recKXL1QrW8qTw5Ux","label":"mentions"},{"source":"recWjGiEd3zqrWNRB","target":"recMNT9RB1RJiLlYW","label":"event"}],"verses":[{"id":"recqsFGGX21XvfwjJ","ref":"Job.37.1","text":"At this also my heart trembleth, and is moved out of his place.","year":-1520},{"id":"recG9eoUlngGSCOWz","ref":"Job.37.2","text":"Hear attentively the noise of his voice, and the sound that goeth out of his mouth.","year":-1520},{"id":"recf0wiYWbDoLUqEJ","ref":"Job.37.3","text":"He directeth it under the whole heaven, and his lightning unto the ends of the earth.","year":-1520},{"id":"reclMKH19OLdM8b43","ref":"Job.37.4","text":"After it a voice roareth: he thundereth with the voice of his excellency; and he will not stay them when his voice is heard.","year":-1520},{"id":"recAqPbMuQc6ZCoEm","ref":"Job.37.5","text":"God thundereth marvellously with his voice; great things doeth he, which we cannot comprehend.","year":-1520},{"id":"rec3Q81orUeVfF4wE","ref":"Job.37.6","text":"For he saith to the snow, Be thou on the earth; likewise to the small rain, and to the great rain of his strength.","year":-1520},{"id":"recoAfyMEwFiIVvdu","ref":"Job.37.7","text":"He sealeth up the hand of every man; that all men may know his work.","year":-1520},{"id":"recqXrALMzqjQloIf","ref":"Job.37.8","text":"Then the beasts go into dens, and remain in their places.","year":-1520}]}
