:"reciEISvqXZeNOWEg","target":"recgFPXlIpiBLSGVM","label":"mentions"},{"source":"reciEISvqXZeNOWEg","target":"recKVcmD8sW9z9clp","label":"mentions"},{"source":"reciEISvqXZeNOWEg","target":"recTmLtzNBGYaxeSZ","label":"mentions"},{"source":"reciEISvqXZeNOWEg","target":"rec9ygL3vIbmQQtNQ","label":"mentions"}],"verses":[{"id":"recDcPH6m4pkP84QL","ref":"Ezra.8.1","text":"These are now the chief of their fathers, and this is the genealogy of them that went up with me from Babylon, in the reign of Artaxerxes the king.","year":-457},{"id":"recvfPTdnJofBglAj","ref":"Ezra.8.2","text":"Of the sons of Phinehas; Gershom: of the sons of Ithamar; Daniel: of the sons of David; Hattush.","year":-457},{"id":"recrQYFuUpUVIPDlJ","ref":"Ezra.8.3","text":"Of the sons of Shechaniah, of the sons of Pharosh; Zechariah: and with him were reckoned by genealogy of the males an hundred and fifty.","year":-457},{"id":"rec3ECyRArOj3KoIq","ref":"Ezra.8.4","text":"Of the sons of Pahathmoab; Elihoenai the son of Zerahiah, and with him two hundred males.","year":-457},{"id":"reciwUo645FLISnPb","ref":"Ezra.8.5","text":"Of the sons of Shechaniah; the son of Jahaziel, and with him three hundred males.","year":-457},{"id":"recmynXbD3sM7Lfq8","ref":"Ezra.8.6","text":"Of the sons also of Adin; Ebed the son of Jonathan, and with him fifty males.","year":-457},{"id":"reczMaNGOXLXdaYf6","ref":"Ezra.8.7","text":"And of the sons of Elam; Jeshaiah the son of Athaliah, and with him seventy males.","year":-457},{"id":"recRKVtCC4FWMpux0","ref":"Ezra.8.8","text":"And of the sons of Shephatiah; Zebadiah the son of Michael, and with him fourscore males.","year":-457}]}
