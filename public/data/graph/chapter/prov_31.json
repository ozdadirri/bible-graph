{"entity":{"id":"recoHiPrKLjyaawuQ","type":"chapter","slug":"recoHiPrKLjyaawuQ","label":"Prov.31","rawId":"recoHiPrKLjyaawuQ","book":{"id":"recRLdYtz1vjdW7yd","type":"book","slug":"prov","label":"Proverbs","subtitle":"Poetry-Wisdom","count":915,"description":"31 chapters, 100 people, 0 places"}},"stats":{"verses":31,"people":3,"places":0,"events":0},"nodes":[{"id":"recoHiPrKLjyaawuQ","type":"chapter","group":"focus","label":"Prov.31","slug":"prov_31","score":31},{"id":"recRLdYtz1vjdW7yd","type":"book","group":"book","label":"Proverbs","slug":"prov","score":915},{"id":"recNDf6kLhjPBivdO","type":"person","group":"mentioned","label":"Lemuel","slug":"lemuel_1817","score":2},{"id":"recHDMqmPBwzMBJl7","type":"person","group":"mentioned","label":"Mother of Lemuel","slug":"mother_of_lemuel_2110","score":1},{"id":"reccZB8SVU5bEMcgo","type":"person","group":"mentioned","label":"God","slug":"god_1324","score":1}],"links":[{"source":"recoHiPrKLjyaawuQ","target":"recRLdYtz1vjdW7yd","label":"part of"},{"source":"recoHiPrKLjyaawuQ","target":"recNDf6kLhjPBivdO","label":"mentions"},{"source":"recoHiPrKLjyaawuQ","target":"recHDMqmPBwzMBJl7","label":"mentions"},{"source":"recoHiPrKLjyaawuQ","target":"reccZB8SVU5bEMcgo","label":"mentions"}],"verses":[{"id":"recs2jS7C36KblKDf","ref":"Prov.31.1","text":"The words of king Lemuel, the prophecy that his mother taught him.","year":-700},{"id":"recH6H6O9a0fSskFb","ref":"Prov.31.2","text":"What, my son? and what, the son of my womb? and what, the son of my vows?","year":-700},{"id":"rec9uEqhmgdrGhuO6","ref":"Prov.31.3","text":"Give not thy strength unto women, nor thy ways to that which destroyeth kings.","year":-700},{"id":"recuTyEkePxgb4T3m","ref":"Prov.31.4","text":"It is not for kings, O Lemuel, it is not for kings to drink wine; nor for princes strong drink:","year":-700},{"id":"recvLNtJ8VR3BmP0e","ref":"Prov.31.5","text":"Lest they drink, and forget the law, and pervert the judgment of any of the afflicted.","year":-700},{"id":"recB1wEukfgls1fGk","ref":"Prov.31.6","text":"Give strong drink unto him that is ready to perish, and wine unto those that be of heavy hearts.","year":-700},{"id":"rec7IRhp6Jyp7JkAB","ref":"Prov.31.7","text":"Let him drink, and forget his poverty, and remember his misery no more.","year":-700},{"id":"reccN5Zj4z0nTltE1","ref":"Prov.31.8","text":"Open thy mouth for the dumb in the cause of all such as are appointed to destruction.","year":-700}]}
