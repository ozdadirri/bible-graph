},{"id":"rec9jLf2r3N4jxyk6","ref":"Num.1.2","text":"Take ye the sum of all the congregation of the children of Israel, after their families, by the house of their fathers, with the number of their names, every male by their polls;","year":-1490},{"id":"rec1DD5rs1bOF8C2W","ref":"Num.1.3","text":"From twenty years old and upward, all that are able to go forth to war in Israel: thou and Aaron shall number them by their armies.","year":-1490},{"id":"rec2Ydm2gKk6kJLNr","ref":"Num.1.4","text":"And with you there shall be a man of every tribe; every one head of the house of his fathers.","year":-1490},{"id":"rec22ikXaWw61QLNy","ref":"Num.1.5","text":"And these are the names of the men that shall stand with you: of the tribe of Reuben; Elizur the son of Shedeur.","year":-1490},{"id":"recLrNkhHgdkN7FBe","ref":"Num.1.6","text":"Of Simeon; Shelumiel the son of Zurishaddai.","year":-1490},{"id":"recrobd5uKcnLO5xp","ref":"Num.1.7","text":"Of Judah; Nahshon the son of Amminadab.","year":-1490},{"id":"recnZZgY8RtjL6Yym","ref":"Num.1.8","text":"Of Issachar; Nethaneel the son of Zuar.","year":-1490}]}
