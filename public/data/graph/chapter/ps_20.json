{"entity":{"id":"recWC1YKYkxvQQUeW","type":"chapter","slug":"recWC1YKYkxvQQUeW","label":"Ps.20","rawId":"recWC1YKYkxvQQUeW","book":{"id":"recKXZXO6cJwk2SxO","type":"book","slug":"ps","label":"Psalms","subtitle":"Poetry-Wisdom","count":2461,"description":"150 chapters, 1026 people, 118 places"}},"stats":{"verses":9,"people":2,"places":1,"events":0},"nodes":[{"id":"recWC1YKYkxvQQUeW","type":"chapter","group":"focus","label":"Ps.20","slug":"ps_20","score":9},{"id":"recKXZXO6cJwk2SxO","type":"book","group":"book","label":"Psalms","slug":"ps","score":2461},{"id":"reccZB8SVU5bEMcgo","type":"person","group":"mentioned","label":"God","slug":"god_1324","score":5},{"id":"recsU2ZSdzBvDqzgI","type":"person","group":"mentioned","label":"Jacob (Israel)","slug":"israel_682","score":1},{"id":"reczPjeq0UdahiRrn","type":"place","group":"mentioned","label":"Zion","slug":"zion_1263","score":1}],"links":[{"source":"recWC1YKYkxvQQUeW","target":"recKXZXO6cJwk2SxO","label":"part of"},{"source":"recWC1YKYkxvQQUeW","target":"reccZB8SVU5bEMcgo","label":"mentions"},{"source":"recWC1YKYkxvQQUeW","target":"recsU2ZSdzBvDqzgI","label":"mentions"},{"source":"recWC1YKYkxvQQUeW","target":"reczPjeq0UdahiRrn","label":"mentions"}],"verses":[{"id":"rec7tyjkODe0a8jhM","ref":"Ps.20.1","text":"The LORD hear thee in the day of trouble; the name of the God of Jacob defend thee;","year":-1036},{"id":"recWwh7dgWZ8Wz31X","ref":"Ps.20.2","text":"Send thee help from the sanctuary, and strengthen thee out of Zion;","year":-1036},{"id":"reckiZt6hwN1OdVwu","ref":"Ps.20.3","text":"Remember all thy offerings, and accept thy burnt sacrifice; Selah.","year":-1036},{"id":"recHqiS4ae3qQxPLJ","ref":"Ps.20.4","text":"Grant thee according to thine own heart, and fulfil all thy counsel.","year":-1036},{"id":"recxwuEr19fuwN1Lt","ref":"Ps.20.5","text":"We will rejoice in thy salvation, and in the name of our God we will set up our banners: the LORD fulfil all thy petitions.","year":-1036},{"id":"recsCB5EeJodCE96Y","ref":"Ps.20.6","text":"Now know I that the LORD saveth his anointed; he will hear him from his holy heaven with the saving strength of his right hand.","year":-1036},{"id":"recMIigQ2rSvxiHYW","ref":"Ps.20.7","text":"Some trust in chariots, and some in horses: but we will remember the name of the LORD our God.","year":-1036},{"id":"recfhClOPXZ28Yh3u","ref":"Ps.20.8","text":"They are brought down and fallen: but we are risen, and stand upright.","year":-1036}]}
