ecWhosCfy5IVd2fU","type":"place","group":"mentioned","label":"Ijon","slug":"ijon_594","score":1},{"id":"recE4R1DFGiDMLM5y","type":"place","group":"mentioned","label":"Geba","slug":"geba_447","score":1},{"id":"recGdQVod5SbLO87Z","type":"place","group":"mentioned","label":"Mizpah","slug":"mizpah_811","score":1}],"links":[{"source":"receIfAFt658FpqOI","target":"rec410yOewjNfbeE3","label":"part of"},{"source":"receIfAFt658FpqOI","target":"recaraSBvlHIwaaOB","label":"mentions"},{"source":"receIfAFt658FpqOI","target":"reccZB8SVU5bEMcgo","label":"mentions"},{"source":"receIfAFt658FpqOI","target":"recBshoEF7PEnjaAy","label":"mentions"},{"source":"receIfAFt658FpqOI","target":"recGpetgbThAidJR4","label":"mentions"},{"source":"receIfAFt658FpqOI","target":"recwqzXQjpmdyyW9y","label":"mentions"},{"source":"receIfAFt658FpqOI","target":"recmAUAIwW85ajksn","label":"mentions"},{"source":"receIfAFt658FpqOI","target":"recV1XqmNcmWio8p5","label":"mentions"},{"source":"receIfAFt658FpqOI","target":"rec1ZMFtfbEvoGC73","label":"mentions"},{"source":"receIfAFt658FpqOI","target":"rectFOmd9oBb0DoQ1","label":"mentions"},{"source":"receIfAFt658FpqOI","target":"recEoYRAyVeAancS0","label":"mentions"},{"source":"receIfAFt658FpqOI","target":"recR67sC02MfTx4al","label":"mentions"},{"source":"receIfAFt658FpqOI","target":"recwFUncFiNWPsPWN","label":"mentions"},{"source":"receIfAFt658FpqOI","target":"recvBrqC52ifM2FSm","label":"mentions"},{"source":"receIfAFt658FpqOI","target":"recWhosCfy5IVd2fU","label":"mentions"},{"source":"receIfAFt658FpqOI","target":"recE4R1DFGiDMLM5y","label":"mentions"},{"source":"receIfAFt658FpqOI","target":"recGdQVod5SbLO87Z","label":"mentions"}],"verses":[{"id":"rech941MYcM5svEGX","ref":"2Chr.16.1","text":"In the six and thirtieth year of the reign of Asa Baasha king of Israel came up against Judah, and built Ramah, to the intent that he might let none go out or come in to Asa king of Judah.","year":-930},{"id":"recyOOrGxOefjBXy5","ref":"2Chr.16.2","text":"Then Asa brought out silver and gold out of the treasures of the house of the LORD and of the king’s house, and sent to Benhadad king of Syria, that dwelt at Damascus, saying,","year":-930},{"id":"receroiWc4uytlrFD","ref":"2Chr.16.3","text":"There is a league between me and thee, as there was between my father and thy father: behold, I have sent thee silver and gold; go, break thy league with Baasha king of Israel, that he may depart from me.","year":-930},{"id":"reclEq3lKBRKZeEUq","ref":"2Chr.16.4","text":"And Benhadad hearkened unto king Asa, and sent the captains of his armies against the cities of Israel; and they smote Ijon, and Dan, and Abelmaim, and all the store cities of Naphtali.","year":-930},{"id":"recLuYDoq6QHPEpAc","ref":"2Chr.16.5","text":"And it came to pass, when Baasha heard it, that he left off building of Ramah, and let his work cease.","year":-930},{"id":"recqwVGNaVcgACn64","ref":"2Chr.16.6","text":"Then Asa the king took all Judah; and they carried away the stones of Ramah, and the timber thereof, wherewith Baasha was building; and he built therewith Geba and Mizpah.","year":-930},{"id":"recnnOZwjUBpYfdUD","ref":"2Chr.16.7","text":"And at that time Hanani the seer came to Asa king of Judah, and said unto him, Because thou hast relied on the king of Syria, and not relied on the LORD thy God, therefore is the host of the king of Syria escaped out of thine hand.","year":-930},{"id":"recWG9DhLQlgyPGIM","ref":"2Chr.16.8","text":"Were not the Ethiopians and the Lubims a huge host, with very many chariots and horsemen? yet, because thou didst rely on the LORD, he delivered them into thine hand.","year":-930}]}
