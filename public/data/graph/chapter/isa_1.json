s","target":"reccZB8SVU5bEMcgo","label":"mentions"},{"source":"recStU2XGk8b6PoYs","target":"recit3DiamFt2zO0S","label":"mentions"},{"source":"recStU2XGk8b6PoYs","target":"reclPYWgWZWK5ccsg","label":"mentions"},{"source":"recStU2XGk8b6PoYs","target":"recZOriotFt9GIf6b","label":"mentions"},{"source":"recStU2XGk8b6PoYs","target":"recRMsfahAI4RmTZe","label":"mentions"},{"source":"recStU2XGk8b6PoYs","target":"recQoq4AXnZxZhOFh","label":"mentions"},{"source":"recStU2XGk8b6PoYs","target":"recNlVijtEIdQhAIm","label":"mentions"},{"source":"recStU2XGk8b6PoYs","target":"reczPjeq0UdahiRrn","label":"mentions"},{"source":"recStU2XGk8b6PoYs","target":"rec34nlC2Rt0dlYyu","label":"mentions"},{"source":"recStU2XGk8b6PoYs","target":"recEwQ7ucCWe9yVvi","label":"mentions"},{"source":"recStU2XGk8b6PoYs","target":"recL1WV82pXaRBQ59","label":"mentions"},{"source":"recStU2XGk8b6PoYs","target":"recQ1bj3p4Lj5MYY6","label":"event"}],"verses":[{"id":"rec8FYqlhjFHJKevZ","ref":"Isa.1.1","text":"The vision of Isaiah the son of Amoz, which he saw concerning Judah and Jerusalem in the days of Uzziah, Jotham, Ahaz, and Hezekiah, kings of Judah.","year":-759},{"id":"rec2JkknX3cvDRSCa","ref":"Isa.1.2","text":"Hear, O heavens, and give ear, O earth: for the LORD hath spoken, I have nourished and brought up children, and they have rebelled against me.","year":-759},{"id":"rec7aE942mczsmDoz","ref":"Isa.1.3","text":"The ox knoweth his owner, and the ass his master’s crib: but Israel doth not know, my people doth not consider.","year":-759},{"id":"recMKTx7Uieg5ET0n","ref":"Isa.1.4","text":"Ah sinful nation, a people laden with iniquity, a seed of evildoers, children that are corrupters: they have forsaken the LORD, they have provoked the Holy One of Israel unto anger, they are gone away backward.","year":-759},{"id":"rec99U6f9bz3KcFFK","ref":"Isa.1.5","text":"Why should ye be stricken any more? ye will revolt more and more: the whole head is sick, and the whole heart faint.","year":-759},{"id":"recuQwWBw2NOTegWo","ref":"Isa.1.6","text":"From the sole of the foot even unto the head there is no soundness in it; but wounds, and bruises, and putrifying sores: they have not been closed, neither bound up, neither mollified with ointment.","year":-759},{"id":"rec5pGfVfsfeDzp8g","ref":"Isa.1.7","text":"Your country is desolate, your cities are burned with fire: your land, strangers devour it in your presence, and it is desolate, as overthrown by strangers.","year":-759},{"id":"rec6ukqVUyNtKDUUj","ref":"Isa.1.8","text":"And the daughter of Zion is left as a cottage in a vineyard, as a lodge in a garden of cucumbers, as a besieged city.","year":-759}]}
