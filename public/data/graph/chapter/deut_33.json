gwbzKA","target":"recwqzXQjpmdyyW9y","label":"mentions"},{"source":"recNnMr6H5HgwbzKA","target":"rec6V51IWkgvAcnOU","label":"mentions"},{"source":"recNnMr6H5HgwbzKA","target":"rec9FmVbRkqnkXn8n","label":"mentions"},{"source":"recNnMr6H5HgwbzKA","target":"rectcV1i4v4cA0JNn","label":"mentions"},{"source":"recNnMr6H5HgwbzKA","target":"recBXbYnzkMDyU8cP","label":"mentions"},{"source":"recNnMr6H5HgwbzKA","target":"recMWJmwqs8BsePBv","label":"mentions"},{"source":"recNnMr6H5HgwbzKA","target":"recgdvRbWEPMp5I0z","label":"mentions"}],"verses":[{"id":"rec96PiPxkPFzT2yb","ref":"Deut.33.1","text":"And this is the blessing, wherewith Moses the man of God blessed the children of Israel before his death.","year":-1451},{"id":"recuaEY0LJP3imDqW","ref":"Deut.33.2","text":"And he said, The LORD came from Sinai, and rose up from Seir unto them; he shined forth from mount Paran, and he came with ten thousands of saints: from his right hand went a fiery law for them.","year":-1451},{"id":"recJyyjQdP9KtWTwm","ref":"Deut.33.3","text":"Yea, he loved the people; all his saints are in thy hand: and they sat down at thy feet; every one shall receive of thy words.","year":-1451},{"id":"rec7EPSKp6Qry6LKy","ref":"Deut.33.4","text":"Moses commanded us a law, even the inheritance of the congregation of Jacob.","year":-1451},{"id":"recDvorRtNQSzTzwZ","ref":"Deut.33.5","text":"And he was king in Jeshurun, when the heads of the people and the tribes of Israel were gathered together.","year":-1451},{"id":"recmflCPW8AbUrERP","ref":"Deut.33.6","text":"Let Reuben live, and not die; and let not his men be few.","year":-1451},{"id":"rec8Q8o8PHbJuYqlC","ref":"Deut.33.7","text":"And this is the blessing of Judah: and he said, Hear, LORD, the voice of Judah, and bring him unto his people: let his hands be sufficient for him; and be thou an help to him from his enemies.","year":-1451},{"id":"recGPk6W2vqW8Zi6R","ref":"Deut.33.8","text":"And of Levi he said, Let thy Thummim and thy Urim be with thy holy one, whom thou didst prove at Massah, and with whom thou didst strive at the waters of Meribah;","year":-1451}]}
