ec8Xwv1TNVXnXwNj","type":"place","group":"mentioned","label":"Ziph","slug":"ziph_1266","score":1},{"id":"recKRsEFLaEueJvei","type":"event","group":"event","label":"Reign of Saul","slug":"event-155","score":25}],"links":[{"source":"recOuyxAS0aVmC8lJ","target":"rec4GS8yWh2R4mpdB","label":"part of"},{"source":"recOuyxAS0aVmC8lJ","target":"rec1ZMFtfbEvoGC73","label":"mentions"},{"source":"recOuyxAS0aVmC8lJ","target":"recjMT68aIzFLh6cQ","label":"mentions"},{"source":"recOuyxAS0aVmC8lJ","target":"reccZB8SVU5bEMcgo","label":"mentions"},{"source":"recOuyxAS0aVmC8lJ","target":"recX02UfwuM8OP0p3","label":"mentions"},{"source":"recOuyxAS0aVmC8lJ","target":"recP6fsKEckt8QTDh","label":"mentions"},{"source":"recOuyxAS0aVmC8lJ","target":"recrbHt1aIhDhOtMN","label":"mentions"},{"source":"recOuyxAS0aVmC8lJ","target":"recbHTp50KvyxmnHE","label":"mentions"},{"source":"recOuyxAS0aVmC8lJ","target":"recJw17QwH6On5LvC","label":"mentions"},{"source":"recOuyxAS0aVmC8lJ","target":"recjLXb7c8RjZDfMS","label":"mentions"},{"source":"recOuyxAS0aVmC8lJ","target":"reci5XsSfPw9RZWBA","label":"mentions"},{"source":"recOuyxAS0aVmC8lJ","target":"recEQYY5s2c3PGUaS","label":"mentions"},{"source":"recOuyxAS0aVmC8lJ","target":"recrlHhIVY61kUrxt","label":"mentions"},{"source":"recOuyxAS0aVmC8lJ","target":"recADz5cMmoTWAEzV","label":"mentions"},{"source":"recOuyxAS0aVmC8lJ","target":"rec8Xwv1TNVXnXwNj","label":"mentions"},{"source":"recOuyxAS0aVmC8lJ","target":"recKRsEFLaEueJvei","label":"event"}],"verses":[{"id":"recKLSyPlrcrHdqi3","ref":"1Sam.26.1","text":"And the Ziphites came unto Saul to Gibeah, saying, Doth not David hide himself in the hill of Hachilah, which is before Jeshimon?","year":-1060},{"id":"rec6ede5YNZznvrFM","ref":"1Sam.26.2","text":"Then Saul arose, and went down to the wilderness of Ziph, having three thousand chosen men of Israel with him, to seek David in the wilderness of Ziph.","year":-1060},{"id":"recvu2ogd9sgJhpSh","ref":"1Sam.26.3","text":"And Saul pitched in the hill of Hachilah, which is before Jeshimon, by the way. But David abode in the wilderness, and he saw that Saul came after him into the wilderness.","year":-1060},{"id":"rec7N3TKN7x8icHWb","ref":"1Sam.26.4","text":"David therefore sent out spies, and understood that Saul was come in very deed.","year":-1060},{"id":"recDq84N0clUzFSYy","ref":"1Sam.26.5","text":"And David arose, and came to the place where Saul had pitched: and David beheld the place where Saul lay, and Abner the son of Ner, the captain of his host: and Saul lay in the trench, and the people pitched round about him.","year":-1060},{"id":"rec35lPt9tmIw1WYd","ref":"1Sam.26.6","text":"Then answered David and said to Ahimelech the Hittite, and to Abishai the son of Zeruiah, brother to Joab, saying, Who will go down with me to Saul to the camp? And Abishai said, I will go down with thee.","year":-1060},{"id":"recHwsSv6DvgMF1Vc","ref":"1Sam.26.7","text":"So David and Abishai came to the people by night: and, behold, Saul lay sleeping within the trench, and his spear stuck in the ground at his bolster: but Abner and the people lay round about him.","year":-1060},{"id":"recPgAFoIDAfpN0nQ","ref":"1Sam.26.8","text":"Then said Abishai to David, God hath delivered thine enemy into thine hand this day: now therefore let me smite him, I pray thee, with the spear even to the earth at once, and I will not smite him the second time.","year":-1060}]}
