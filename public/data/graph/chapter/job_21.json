{"entity":{"id":"recjZskXPnJonUv72","type":"chapter","slug":"recjZskXPnJonUv72","label":"Job.21","rawId":"recjZskXPnJonUv72","book":{"id":"recOA8nVVhKs30PSI","type":"book","slug":"job","label":"Job","subtitle":"Poetry-Wisdom","count":1070,"description":"42 chapters, 190 people, 6 places"}},"stats":{"verses":34,"people":2,"places":0,"events":1},"nodes":[{"id":"recjZskXPnJonUv72","type":"chapter","group":"focus","label":"Job.21","slug":"job_21","score":34},{"id":"recOA8nVVhKs30PSI","type":"book","group":"book","label":"Job","slug":"job","score":1070},{"id":"reccZB8SVU5bEMcgo","type":"person","group":"mentioned","label":"God","slug":"god_1324","score":7},{"id":"recKXL1QrW8qTw5Ux","type":"person","group":"mentioned","label":"Job","slug":"job_1639","score":1},{"id":"recMNT9RB1RJiLlYW","type":"event","group":"event","label":"Job's Trial","slug":"event-117","score":34}],"links":[{"source":"recjZskXPnJonUv72","target":"recOA8nVVhKs30PSI","label":"part of"},{"source":"recjZskXPnJonUv72","target":"reccZB8SVU5bEMcgo","label":"mentions"},{"source":"recjZskXPnJonUv72","target":"recKXL1QrW8qTw5Ux","label":"mentions"},{"source":"recjZskXPnJonUv72","target":"recMNT9RB1RJiLlYW","label":"event"}],"verses":[{"id":"rec726VTmzVHenp32","ref":"Job.21.1","text":"But Job answered and said,","year":-1520},{"id":"rectKr0sNBusXf9Re","ref":"Job.21.2","text":"Hear diligently my speech, and let this be your consolations.","year":-1520},{"id":"recCU8Pc0TXVcMpDi","ref":"Job.21.3","text":"Suffer me that I may speak; and after that I have spoken, mock on.","year":-1520},{"id":"recmdVqTSEEKH7Xv2","ref":"Job.21.4","text":"As for me, is my complaint to man? and if it were so, why should not my spirit be troubled?","year":-1520},{"id":"recfRDjcGhvBHnqvl","ref":"Job.21.5","text":"Mark me, and be astonished, and lay your hand upon your mouth.","year":-1520},{"id":"recaIlqBjaTk5smRK","ref":"Job.21.6","text":"Even when I remember I am afraid, and trembling taketh hold on my flesh.","year":-1520},{"id":"recPvxKVEXruSzNNd","ref":"Job.21.7","text":"Wherefore do the wicked live, become old, yea, are mighty in power?","year":-1520},{"id":"recRgdyhjAfu3XEBD","ref":"Job.21.8","text":"Their seed is established in their sight with them, and their offspring before their eyes.","year":-1520}]}
