IMLCvH","target":"reccZB8SVU5bEMcgo","label":"mentions"},{"source":"recjzxr9YqcIMLCvH","target":"recsU2ZSdzBvDqzgI","label":"mentions"},{"source":"recjzxr9YqcIMLCvH","target":"recE9nWKk1vLR7zi1","label":"mentions"},{"source":"recjzxr9YqcIMLCvH","target":"recgAScrne6IJlIRY","label":"mentions"},{"source":"recjzxr9YqcIMLCvH","target":"recfrXyxhuYOczKTm","label":"mentions"},{"source":"recjzxr9YqcIMLCvH","target":"recIJFRcqI6KbKgXb","label":"mentions"},{"source":"recjzxr9YqcIMLCvH","target":"recL1WV82pXaRBQ59","label":"mentions"},{"source":"recjzxr9YqcIMLCvH","target":"recuBx2LEnNR6q2X3","label":"mentions"},{"source":"recjzxr9YqcIMLCvH","target":"receEjvf5hXhkgVuZ","label":"mentions"},{"source":"recjzxr9YqcIMLCvH","target":"recHAv7LzOUc4wj2r","label":"mentions"},{"source":"recjzxr9YqcIMLCvH","target":"rec1RMZhQrrzq5oHJ","label":"mentions"},{"source":"recjzxr9YqcIMLCvH","target":"rec5pDuWtEaOK7ehk","label":"event"}],"verses":[{"id":"recZKG9VsSMOnvmG7","ref":"Jer.2.1","text":"Moreover the word of the LORD came to me, saying,","year":-629},{"id":"recbPP1m2aZr25yEK","ref":"Jer.2.2","text":"Go and cry in the ears of Jerusalem, saying, Thus saith the LORD; I remember thee, the kindness of thy youth, the love of thine espousals, when thou wentest after me in the wilderness, in a land that was not sown.","year":-629},{"id":"rectyI8T4zUMpgETl","ref":"Jer.2.3","text":"Israel was holiness unto the LORD, and the firstfruits of his increase: all that devour him shall offend; evil shall come upon them, saith the LORD.","year":-629},{"id":"reca7lGAIPlzeM6uU","ref":"Jer.2.4","text":"Hear ye the word of the LORD, O house of Jacob, and all the families of the house of Israel:","year":-629},{"id":"recnWNpxlVezmguwJ","ref":"Jer.2.5","text":"Thus saith the LORD, What iniquity have your fathers found in me, that they are gone far from me, and have walked after vanity, and are become vain?","year":-629},{"id":"recSktbLj7wFcDp3O","ref":"Jer.2.6","text":"Neither said they, Where is the LORD that brought us up out of the land of Egypt, that led us through the wilderness, through a land of deserts and of pits, through a land of drought, and of the shadow of death, through a land that no man passed through, and where no man dwelt?","year":-629},{"id":"recnsCMLZakUeu2te","ref":"Jer.2.7","text":"And I brought you into a plentiful country, to eat the fruit thereof and the goodness thereof; but when ye entered, ye defiled my land, and made mine heritage an abomination.","year":-629},{"id":"recqGxf4OcPxSDhJw","ref":"Jer.2.8","text":"The priests said not, Where is the LORD? and they that handle the law knew me not: the pastors also transgressed against me, and the prophets prophesied by Baal, and walked after things that do not profit.","year":-629}]}
