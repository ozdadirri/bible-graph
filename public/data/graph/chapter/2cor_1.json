rget":"recgkFqZovgbr3pAi","label":"mentions"},{"source":"recikRt8RL0hvJ1Jr","target":"recIRlDcRDv2MBfxW","label":"mentions"},{"source":"recikRt8RL0hvJ1Jr","target":"recgkzNX07a7kGFYL","label":"mentions"},{"source":"recikRt8RL0hvJ1Jr","target":"recSo7V3yW4zpZBLM","label":"mentions"},{"source":"recikRt8RL0hvJ1Jr","target":"reco82mzy0XTzaOgv","label":"mentions"},{"source":"recikRt8RL0hvJ1Jr","target":"recQThsW3uau1oxf9","label":"mentions"},{"source":"recikRt8RL0hvJ1Jr","target":"recj2XUqaJxCKA6qs","label":"mentions"},{"source":"recikRt8RL0hvJ1Jr","target":"recpCMN0bRpzByjaR","label":"mentions"},{"source":"recikRt8RL0hvJ1Jr","target":"recly2TmP9CBHh8OQ","label":"mentions"},{"source":"recikRt8RL0hvJ1Jr","target":"recAalC2QoLT7cJKN","label":"mentions"}],"verses":[{"id":"recTgys1iuuYXWikh","ref":"2Cor.1.1","text":"Paul, an apostle of Jesus Christ by the will of God, and Timothy our brother, unto the church of God which is at Corinth, with all the saints which are in all Achaia:","year":60},{"id":"recnI8HCkDh00wTUY","ref":"2Cor.1.2","text":"Grace be to you and peace from God our Father, and from the Lord Jesus Christ.","year":60},{"id":"recY2JXeWaZKrmkgu","ref":"2Cor.1.3","text":"Blessed be God, even the Father of our Lord Jesus Christ, the Father of mercies, and the God of all comfort;","year":60},{"id":"recJvpGqu3b3hyP0g","ref":"2Cor.1.4","text":"Who comforteth us in all our tribulation, that we may be able to comfort them which are in any trouble, by the comfort wherewith we ourselves are comforted of God.","year":60},{"id":"recrIxw8EHbYnYgsv","ref":"2Cor.1.5","text":"For as the sufferings of Christ abound in us, so our consolation also aboundeth by Christ.","year":60},{"id":"recRg1oijkO2n63Nr","ref":"2Cor.1.6","text":"And whether we be afflicted, it is for your consolation and salvation, which is effectual in the enduring of the same sufferings which we also suffer: or whether we be comforted, it is for your consolation and salvation.","year":60},{"id":"recPIxZniV2UeSALH","ref":"2Cor.1.7","text":"And our hope of you is stedfast, knowing, that as ye are partakers of the sufferings, so shall ye be also of the consolation.","year":60},{"id":"recgvAzuLu1Wd4qkX","ref":"2Cor.1.8","text":"For we would not, brethren, have you ignorant of our trouble which came to us in Asia, that we were pressed out of measure, above strength, insomuch that we despaired even of life:","year":60}]}
