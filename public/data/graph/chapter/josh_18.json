2YWS","label":"mentions"},{"source":"recxuWU3OCo5xhz5S","target":"rec5dSSsOutWlH2fW","label":"mentions"},{"source":"recxuWU3OCo5xhz5S","target":"recVYcDguYN6bVqxy","label":"mentions"},{"source":"recxuWU3OCo5xhz5S","target":"recdMHFSmu222VnJG","label":"mentions"},{"source":"recxuWU3OCo5xhz5S","target":"recJK76HLZSOzxTWW","label":"mentions"},{"source":"recxuWU3OCo5xhz5S","target":"recRg102TEaTaifd2","label":"mentions"},{"source":"recxuWU3OCo5xhz5S","target":"recgAmwf1FZDe8DST","label":"mentions"},{"source":"recxuWU3OCo5xhz5S","target":"rec7ux6O0fwgSs7Cw","label":"mentions"},{"source":"recxuWU3OCo5xhz5S","target":"recFkoFKnoYZeBqsi","label":"mentions"},{"source":"recxuWU3OCo5xhz5S","target":"recRJEQbrGi24OUFZ","label":"mentions"}],"verses":[{"id":"recSJbmKA9zJBBxIE","ref":"Josh.18.1","text":"And the whole congregation of the children of Israel assembled together at Shiloh, and set up the tabernacle of the congregation there. And the land was subdued before them.","year":-1443},{"id":"recRXfkquf66Oybde","ref":"Josh.18.2","text":"And there remained among the children of Israel seven tribes, which had not yet received their inheritance.","year":-1443},{"id":"recbJEi0KkM9JtGNV","ref":"Josh.18.3","text":"And Joshua said unto the children of Israel, How long are ye slack to go to possess the land, which the LORD God of your fathers hath given you?","year":-1443},{"id":"recOT0gFW8s4NMMHt","ref":"Josh.18.4","text":"Give out from among you three men for each tribe: and I will send them, and they shall rise, and go through the land, and describe it according to the inheritance of them; and they shall come again to me.","year":-1443},{"id":"recEBu7GkYPH5Lw4q","ref":"Josh.18.5","text":"And they shall divide it into seven parts: Judah shall abide in their coast on the south, and the house of Joseph shall abide in their coasts on the north.","year":-1443},{"id":"recm4Wd4b1lTiCczo","ref":"Josh.18.6","text":"Ye shall therefore describe the land into seven parts, and bring the description hither to me, that I may cast lots for you here before the LORD our God.","year":-1443},{"id":"recwI5uUsrNFKbuum","ref":"Josh.18.7","text":"But the Levites have no part among you; for the priesthood of the LORD is their inheritance: and Gad, and Reuben, and half the tribe of Manasseh, have received their inheritance beyond Jordan on the east, which Moses the servant of the LORD gave them.","year":-1443},{"id":"recBSBYs7zLP8IsUn","ref":"Josh.18.8","text":"And the men arose, and went away: and Joshua charged them that went to describe the land, saying, Go and walk through the land, and describe it, and come again to me, that I may here cast lots for you before the LORD in Shiloh.","year":-1443}]}
