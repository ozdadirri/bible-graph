{"entity":{"id":"recauwd5QKybhaMf8","type":"chapter","slug":"recauwd5QKybhaMf8","label":"Ps.146","rawId":"recauwd5QKybhaMf8","book":{"id":"recKXZXO6cJwk2SxO","type":"book","slug":"ps","label":"Psalms","subtitle":"Poetry-Wisdom","count":2461,"description":"150 chapters, 1026 people, 118 places"}},"stats":{"verses":10,"people":2,"places":1,"events":0},"nodes":[{"id":"recauwd5QKybhaMf8","type":"chapter","group":"focus","label":"Ps.146","slug":"ps_146","score":10},{"id":"recKXZXO6cJwk2SxO","type":"book","group":"book","label":"Psalms","slug":"ps","score":2461},{"id":"reccZB8SVU5bEMcgo","type":"person","group":"mentioned","label":"God","slug":"god_1324","score":7},{"id":"recsU2ZSdzBvDqzgI","type":"person","group":"mentioned","label":"Jacob (Israel)","slug":"israel_682","score":1},{"id":"reczPjeq0UdahiRrn","type":"place","group":"mentioned","label":"Zion","slug":"zion_1263","score":1}],"links":[{"source":"recauwd5QKybhaMf8","target":"recKXZXO6cJwk2SxO","label":"part of"},{"source":"recauwd5QKybhaMf8","target":"reccZB8SVU5bEMcgo","label":"mentions"},{"source":"recauwd5QKybhaMf8","target":"recsU2ZSdzBvDqzgI","label":"mentions"},{"source":"recauwd5QKybhaMf8","target":"reczPjeq0UdahiRrn","label":"mentions"}],"verses":[{"id":"recwVOIcvikKRMkwc","ref":"Ps.146.1","text":"Praise ye the LORD. Praise the LORD, O my soul.","year":-515},{"id":"reczHeqk4pBpOCoOQ","ref":"Ps.146.2","text":"While I live will I praise the LORD: I will sing praises unto my God while I have any being.","year":-515},{"id":"recw0Kz6NHhkbkRlf","ref":"Ps.146.3","text":"Put not your trust in princes, nor in the son of man, in whom there is no help.","year":-515},{"id":"recWIMw9Dh3O5TbC5","ref":"Ps.146.4","text":"His breath goeth forth, he returneth to his earth; in that very day his thoughts perish.","year":-515},{"id":"recMHDXFhCMrp88xN","ref":"Ps.146.5","text":"Happy is he that hath the God of Jacob for his help, whose hope is in the LORD his God:","year":-515},{"id":"rec9sZDKxQwgCLYzq","ref":"Ps.146.6","text":"Which made heaven, and earth, the sea, and all that therein is: which keepeth truth for ever:","year":-515},{"id":"rec93yfU2cQIa47CQ","ref":"Ps.146.7","text":"Which executeth judgment for the oppressed: which giveth food to the hungry. The LORD looseth the prisoners:","year":-515},{"id":"recB5HQ5rP0J3Dxdw","ref":"Ps.146.8","text":"The LORD openeth the eyes of the blind: the LORD raiseth them that are bowed down: the LORD loveth the righteous:","year":-515}]}
