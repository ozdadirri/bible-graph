abel":"participant"},{"source":"rech8qvzNnkDTqCi3","target":"recL1WV82pXaRBQ59","label":"location"},{"source":"rech8qvzNnkDTqCi3","target":"reciu7dT92C4dTrfl","label":"predecessor"}],"verses":[{"id":"rec4EcFe3TGTOCKx6","ref":"Acts.4.1","text":"And as they spake unto the people, the priests, and the captain of the temple, and the Sadducees, came upon them,","year":33},{"id":"reckhmp4WWKShAz1r","ref":"Acts.4.2","text":"Being grieved that they taught the people, and preached through Jesus the resurrection from the dead.","year":33},{"id":"recrYCcEt8kFKfPD2","ref":"Acts.4.3","text":"And they laid hands on them, and put them in hold unto the next day: for it was now eventide.","year":33},{"id":"recGDW3VtoDqY6ctp","ref":"Acts.4.4","text":"Howbeit many of them which heard the word believed; and the number of the men was about five thousand.","year":33},{"id":"recCcAro16hPB33jU","ref":"Acts.4.5","text":"And it came to pass on the morrow, that their rulers, and elders, and scribes,","year":33},{"id":"recva0JhoZCmtuen7","ref":"Acts.4.6","text":"And Annas the high priest, and Caiaphas, and John, and Alexander, and as many as were of the kindred of the high priest, were gathered together at Jerusalem.","year":33},{"id":"recWd4JUy5TWeZXpr","ref":"Acts.4.7","text":"And when they had set them in the midst, they asked, By what power, or by what name, have ye done this?","year":33},{"id":"rec9uHo6wNbTaymWr","ref":"Acts.4.8","text":"Then Peter, filled with the Holy Ghost, said unto them, Ye rulers of the people, and elders of Israel,","year":33}]}
